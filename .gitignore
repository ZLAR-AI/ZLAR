# Runtime state
var/
*.log

# Live config (generated at install, not distributable)
etc/gate.json
etc/jq.sha256

# Per-install policy rotation archive — grows one file per rotation,
# content is hostname/activity-bound via downstream receipt evidence.
etc/policies/archive/

# Policy ceremony scratch — drafts live here between edit and sign/deploy.
# Never commit; the signed result is deployed to active.policy.json.
etc/policies/draft.json
etc/policies/draft-*.json

# Per-install HMAC tags — bound to local HMAC key, not distributable.
etc/*.hmac

# Generated runtime data (contains hostname, username, activity patterns)
etc/agents.registry.json
etc/agent-policy-bindings.json

# Per-install agent capability manifest (regeneratable via zlar-manifest new,
# identity-bound, time-bounded — not distributable)
etc/manifest.json

# mcp-gate test fixtures: created and deleted by mcp-gate/test.mjs on every
# run — tracking them is meaningless since the test overwrites at setup
# and unlinks at teardown. test-policy-signing.pub is an ephemeral Ed25519
# public key paired with an in-memory private key used to sign the test
# policy under ZLAR spec canonical form.
mcp-gate/test-allow-policy.json
mcp-gate/test-policy-signing.pub

# Keys (generated at install)
etc/keys/

# macOS
.DS_Store

# Editor
*.swp
*.swo
*~

# Environment (may contain Telegram tokens)
.env

# Backup files
*.bak*
*.save
