    },
    {
      "id": "R100",
      "enabled": true,
      "description": "MCP tool calls — require approval (Cursor/Windsurf). MCP tools can do anything; never auto-allow.",
      "domain": "unknown",
      "action": "ask",
      "severity": "warn",
      "audit": true,
      "match": {
        "domain": "unknown"
      },
      "risk_score": {
