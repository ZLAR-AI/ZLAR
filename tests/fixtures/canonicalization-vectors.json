    },
    {
      "id": "C010",
      "description": "Empty string",
      "input": "",
      "expected": "\"\""
    },
    {
      "id": "C011",
      "description": "Simple string",
      "input": "hello",
      "expected": "\"hello\""
    },
    {
      "id": "C012",
      "description": "String with special characters",
      "input": "line1\nline2\ttab",
      "expected": "\"line1\\nline2\\ttab\""
    },
    {
      "id": "C013",
      "description": "String with quotes and backslash",
      "input": "say \"hello\" and \\",
      "expected": "\"say \\\"hello\\\" and \\\\\""
    },
    {
      "id": "C014",
      "description": "String with Unicode (non-ASCII value, which is allowed)",
      "input": "\u65e5\u672c\u8a9e",
      "expected": "\"\u65e5\u672c\u8a9e\""
    },
    {
      "id": "C015",
      "description": "Key ordering — alphabetical",
      "input": {"c": 3, "a": 1, "b": 2},
      "expected": "{\"a\":1,\"b\":2,\"c\":3}"
    },
    {
      "id": "C016",
      "description": "Key ordering — case sensitive (uppercase before lowercase in ASCII)",
      "input": {"b": 2, "A": 1, "a": 3},
      "expected": "{\"A\":1,\"a\":3,\"b\":2}"
    },
    {
      "id": "C017",
      "description": "Key ordering — numbers sort before letters in ASCII",
      "input": {"b": 2, "1": 1, "a": 3},
      "expected": "{\"1\":1,\"a\":3,\"b\":2}"
    },
    {
      "id": "C018",
      "description": "Nested objects — keys sorted recursively",
      "input": {"z": {"b": 2, "a": 1}, "a": {"d": 4, "c": 3}},
      "expected": "{\"a\":{\"c\":3,\"d\":4},\"z\":{\"a\":1,\"b\":2}}"
    },
    {
      "id": "C019",
      "description": "Array of objects — each object sorted, array order preserved",
      "input": [{"z": 1, "a": 2}, {"m": 3, "b": 4}],
      "expected": "[{\"a\":2,\"z\":1},{\"b\":4,\"m\":3}]"
    },
    {
      "id": "C020",
      "description": "Deeply nested structure",
      "input": {"c": {"f": {"i": 9, "h": 8}, "e": 5}, "a": {"d": [3, 2, 1], "b": null}},
      "expected": "{\"a\":{\"b\":null,\"d\":[3,2,1]},\"c\":{\"e\":5,\"f\":{\"h\":8,\"i\":9}}}"
    },
    {
      "id": "C021",
      "description": "Mixed types in array",
      "input": [1, "two", true, null, {"a": 3}],
      "expected": "[1,\"two\",true,null,{\"a\":3}]"
    },
    {
      "id": "C022",
      "description": "Empty nested structures",
      "input": {"a": {}, "b": [], "c": ""},
      "expected": "{\"a\":{},\"b\":[],\"c\":\"\"}"
    },
