{
  "version": "1.1.0",
  "created_at": "2026-03-04T00:00:00Z",
  "author": "admin",
  "description": "ZLAR-OC Phase A policy — observe HTTPS egress for 48h before enforcing allowlist",

  "signature": {
    "algorithm": "ed25519",
    "public_key": "",
    "value": ""
  },

  "default_action": "deny",

  "scoring_thresholds": {
    "allow": 20,
    "log": 50,
    "ask": 80,
    "_comment": "score < allow → auto-allow, < log → log, < ask → ask human, >= ask → deny"
  },

  "rules": [
    {
      "id": "R060",
      "description": "Pass through sandbox denials (already enforced by OS)",
      "enabled": true,
      "match": {
        "source": "sandbox"
      },
      "action": "log",
      "audit": true,
      "severity": "warn"
    },
    {
      "id": "R061",
      "description": "Pass through pf drops (already enforced by OS)",
      "enabled": true,
      "match": {
        "source": "pf"
      },
      "action": "log",
      "audit": true,
      "severity": "warn"
    },
    {
      "id": "R001",
      "description": "Allow read-only system info commands",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "binary": { "in": ["/usr/bin/uname", "/bin/hostname", "/usr/bin/whoami", "/usr/bin/env"] }
        }
      },
      "action": "allow",
      "audit": true,
      "severity": "info"
    },
    {
      "id": "R002",
      "description": "Allow git operations in workspace",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "binary": { "eq": "/usr/bin/git" },
          "cwd": { "prefix": "/Users/aiagent/workspace" }
        }
      },
      "action": "allow",
      "audit": true,
      "severity": "info"
    },
    {
      "id": "R003",
      "description": "Allow ffmpeg/ffprobe for media processing",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "binary": { "in": ["/opt/homebrew/bin/ffmpeg", "/opt/homebrew/bin/ffprobe"] }
        }
      },
      "action": "allow",
      "audit": true,
      "severity": "info"
    },
    {
      "id": "R004",
      "description": "Allow Node.js execution (core runtime)",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "binary": { "in": ["/opt/homebrew/bin/node", "/usr/local/bin/node"] }
        }
      },
      "action": "allow",
      "audit": true,
      "severity": "info"
    },
    {
      "id": "R005",
      "description": "Allow shell execution (required for ProcessSupervisor)",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "binary": { "in": ["/bin/sh", "/bin/bash", "/bin/zsh"] }
        }
      },
      "action": "allow",
      "audit": true,
      "severity": "info"
    },
    {
      "id": "R010",
      "description": "Score unknown shell commands (Stage 2 boundedness gate)",
      "enabled": true,
      "match": {
        "domain": "exec"
      },
      "action": "ask",
      "risk_score": {
        "enabled": true,
        "irreversibility": 60,
        "consequence": 50,
        "blast_radius": 40,
        "_comment": "max(60,50,40)=60 → ask. Unknown exec is moderately risky."
      },
      "ask": {
        "channel": "telegram",
        "timeout_s": 120,
        "timeout_action": "deny",
        "message_template": "OpenClaw wants to run: {{detail.command}}\nBinary: {{detail.binary}}\nRisk score: {{risk_score}}\nSession: {{session}}\nAgent: {{agent}}"
      },
      "audit": true,
      "severity": "warn"
    },
    {
      "id": "R020",
      "description": "Deny all LAN access (defense in depth with pf)",
      "enabled": true,
      "match": {
        "domain": "net.outbound",
        "detail": {
          "dst_ip": { "regex": "^(10\\.|172\\.(1[6-9]|2[0-9]|3[01])\\.|192\\.168\\.|169\\.254\\.)" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 90,
        "consequence": 95,
        "blast_radius": 80,
        "_comment": "max(90,95,80)=95 → deny. LAN access could reach host infrastructure."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R021",
      "description": "Allow HTTPS to known API endpoints",
      "enabled": true,
      "match": {
        "domain": "net.outbound",
        "detail": {
          "dst_host": { "in": [
            "api.anthropic.com",
            "api.openai.com",
            "huggingface.co",
            "cdn-lfs.huggingface.co",
            "github.com",
            "api.github.com"
          ]},
          "dst_port": { "eq": 443 }
        }
      },
      "action": "allow",
      "audit": true,
      "severity": "info"
    },
    {
      "id": "R022",
      "description": "Phase A: Log all HTTPS to unknown hosts (observe for 48h, then promote or block)",
      "enabled": true,
      "match": {
        "domain": "net.outbound",
        "detail": {
          "dst_port": { "in": [443, 80] }
        }
      },
      "action": "log",
      "audit": true,
      "severity": "warn"
    },
    {
      "id": "R030",
      "description": "Deny file access to admin home",
      "enabled": true,
      "match": {
        "domain": "fs",
        "detail": {
          "path": { "prefix": "/Users/admin" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 85,
        "consequence": 95,
        "blast_radius": 70,
        "_comment": "max(85,95,70)=95 → deny. Admin home contains keys, configs, credentials."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R031",
      "description": "Deny file access to ZLAR-OC config",
      "enabled": true,
      "match": {
        "domain": "fs",
        "detail": {
          "path": { "prefix": "/usr/local/etc/zlar-oc" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 100,
        "consequence": 100,
        "blast_radius": 90,
        "_comment": "max(100,100,90)=100 → deny. Self-modification of containment = regulatory erosion."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R032",
      "description": "Deny SSH key access",
      "enabled": true,
      "match": {
        "domain": "fs",
        "detail": {
          "path": { "contains": "/.ssh/" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 95,
        "consequence": 100,
        "blast_radius": 95,
        "_comment": "max(95,100,95)=100 → deny. SSH keys = lateral movement capability."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R033",
      "description": "Deny access to macOS Keychain (credentials, passwords, certificates)",
      "enabled": true,
      "match": {
        "domain": "fs",
        "detail": {
          "path": { "prefix": "/Users/aiagent/Library/Keychains" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 100,
        "consequence": 100,
        "blast_radius": 95,
        "_comment": "max=100 → deny. Keychain contains passwords, certificates, secrets."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R034",
      "description": "Deny access to browser profiles (saved passwords, cookies, history)",
      "enabled": true,
      "match": {
        "domain": "fs",
        "detail": {
          "path": { "regex": "/(Library/Application Support/(Google/Chrome|BraveSoftware|Firefox)|Library/Cookies|Library/Safari)/" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 95,
        "consequence": 100,
        "blast_radius": 90,
        "_comment": "max=100 → deny. Browser profiles contain saved passwords, session tokens, cookies."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R035",
      "description": "Deny access to iCloud Drive and Photos Library",
      "enabled": true,
      "match": {
        "domain": "fs",
        "detail": {
          "path": { "regex": "/(Library/Mobile Documents|Photos Library\\.photoslibrary|iCloud Drive)/" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 90,
        "consequence": 85,
        "blast_radius": 80,
        "_comment": "max=90 → deny. Personal photos and iCloud-synced documents."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R036",
      "description": "Deny access to Desktop and Documents (user personal files)",
      "enabled": true,
      "match": {
        "domain": "fs",
        "detail": {
          "path": { "regex": "^/Users/[^/]+/(Desktop|Documents)/" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 85,
        "consequence": 80,
        "blast_radius": 70,
        "_comment": "max=85 → deny. Personal files that may contain sensitive documents."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R070",
      "description": "Halt on rm -rf or recursive deletion commands",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "command": { "regex": "\\brm\\b.*(-rf|-fr|--recursive)" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 100,
        "consequence": 100,
        "blast_radius": 95,
        "_comment": "max=100 → deny. Recursive deletion is irreversible mass destruction."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R071",
      "description": "Ask before any file deletion (rm, unlink)",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "binary": { "in": ["/bin/rm", "/usr/bin/unlink"] }
        }
      },
      "action": "ask",
      "risk_score": {
        "enabled": true,
        "irreversibility": 70,
        "consequence": 60,
        "blast_radius": 40,
        "_comment": "max=70 → ask. Single file deletion is serious but contained."
      },
      "ask": {
        "channel": "telegram",
        "timeout_s": 120,
        "timeout_action": "deny",
        "message_template": "OpenClaw wants to DELETE: {{detail.command}}\nRisk: {{risk_score}}/100\nAgent: {{agent}}"
      },
      "audit": true,
      "severity": "warn"
    },
    {
      "id": "R072",
      "description": "Ask before chmod/chown (permission changes can lock out access)",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "binary": { "in": ["/bin/chmod", "/usr/sbin/chown", "/usr/bin/chgrp"] }
        }
      },
      "action": "ask",
      "risk_score": {
        "enabled": true,
        "irreversibility": 65,
        "consequence": 70,
        "blast_radius": 50,
        "_comment": "max=70 → ask. Permission changes can make files inaccessible."
      },
      "ask": {
        "channel": "telegram",
        "timeout_s": 120,
        "timeout_action": "deny",
        "message_template": "OpenClaw wants to change permissions: {{detail.command}}\nRisk: {{risk_score}}/100"
      },
      "audit": true,
      "severity": "warn"
    },
    {
      "id": "R073",
      "description": "Deny mv/cp targeting protected paths",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "command": { "regex": "\\b(mv|cp)\\b.*(/Users/admin|/usr/local/etc/zlar-oc|/etc/|/System/)" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 85,
        "consequence": 90,
        "blast_radius": 70,
        "_comment": "max=90 → deny. Moving/copying into protected paths is boundary violation."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R074",
      "description": "Deny git push --force (can destroy remote history)",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "command": { "regex": "git\\s+push.*--force" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 90,
        "consequence": 80,
        "blast_radius": 75,
        "_comment": "max=90 → deny. Force push destroys remote commit history."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R080",
      "description": "Deny osascript execution (macOS scripting bridge — can control any app)",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "binary": { "eq": "/usr/bin/osascript" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 80,
        "consequence": 95,
        "blast_radius": 90,
        "_comment": "max=95 → deny. osascript can send emails, control apps, access keychain."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R081",
      "description": "Deny defaults write (macOS system preferences modification)",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "command": { "regex": "\\bdefaults\\s+write\\b" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 75,
        "consequence": 80,
        "blast_radius": 60,
        "_comment": "max=80 → deny. Can change system behavior, disable security features."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R082",
      "description": "Deny launchctl (persistent daemon management — survives reboot)",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "binary": { "eq": "/bin/launchctl" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 85,
        "consequence": 90,
        "blast_radius": 80,
        "_comment": "max=90 → deny. Loading daemons creates persistent footholds."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R083",
      "description": "Deny networksetup (DNS/proxy/network configuration changes)",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "binary": { "eq": "/usr/sbin/networksetup" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 80,
        "consequence": 95,
        "blast_radius": 85,
        "_comment": "max=95 → deny. Can redirect DNS, add proxies, change network routes."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R084",
      "description": "Deny pmset (power management — your thermostat example)",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "binary": { "eq": "/usr/bin/pmset" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 50,
        "consequence": 60,
        "blast_radius": 40,
        "_comment": "max=60 → ask/deny. Can prevent sleep, change power behavior."
      },
      "audit": true,
      "severity": "warn"
    },
    {
      "id": "R085",
      "description": "Deny security command (Keychain manipulation via CLI)",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "binary": { "eq": "/usr/bin/security" }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 95,
        "consequence": 100,
        "blast_radius": 90,
        "_comment": "max=100 → deny. Can extract passwords, certificates, keys from Keychain."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R086",
      "description": "Deny open command (launches apps, URLs — the thermostat vector)",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "binary": { "eq": "/usr/bin/open" }
        }
      },
      "action": "ask",
      "risk_score": {
        "enabled": true,
        "irreversibility": 40,
        "consequence": 60,
        "blast_radius": 50,
        "_comment": "max=60 → ask. Can open apps, URLs, trigger HomeKit scenes, send emails."
      },
      "ask": {
        "channel": "telegram",
        "timeout_s": 120,
        "timeout_action": "deny",
        "message_template": "OpenClaw wants to open: {{detail.command}}\nThis could launch an app, URL, or system action.\nRisk: {{risk_score}}/100"
      },
      "audit": true,
      "severity": "warn"
    },
    {
      "id": "R087",
      "description": "Deny killall/pkill/kill (process termination — could kill the watchdog)",
      "enabled": true,
      "match": {
        "domain": "exec",
        "detail": {
          "binary": { "in": ["/usr/bin/killall", "/usr/bin/pkill", "/bin/kill"] }
        }
      },
      "action": "deny",
      "risk_score": {
        "enabled": true,
        "irreversibility": 70,
        "consequence": 85,
        "blast_radius": 60,
        "_comment": "max=85 → deny. Could terminate watchdog, gate, or critical processes."
      },
      "audit": true,
      "severity": "critical"
    },
    {
      "id": "R040",
      "description": "Log all browser navigations",
      "enabled": true,
      "match": {
        "domain": "browser.nav"
      },
      "action": "allow",
      "audit": true,
      "severity": "info"
    },
    {
      "id": "R050",
      "description": "Log all sub-agent spawns",
      "enabled": true,
      "match": {
        "domain": "subagent"
      },
      "action": "allow",
      "audit": true,
      "severity": "warn"
    }
  ]
}
