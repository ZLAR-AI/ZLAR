#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
# ZLAR-OC Gate Watchdog
#
# Monitors the gate daemon and enforces fail-closed behavior:
#   - Checks gate PID every INTERVAL seconds
#   - If gate is dead: attempt restart up to MAX_RETRIES times
#   - If restart fails: lock down the agent (kill agent processes)
#   - Emits audit events for every state transition
#
# This is the membrane self-repair mechanism (#8).
# If the gate is compromised or crashes, the watchdog ensures the agent
# cannot operate unobserved.
#
# Usage:
#   zlar-oc-watchdog start [--interval 10] [--max-retries 3]
#   zlar-oc-watchdog stop
#   zlar-oc-watchdog status
#
# Designed to run as a separate launchd daemon (KeepAlive).
# Must NOT run as aiagent.
# ═══════════════════════════════════════════════════════════════════════════════

set -euo pipefail

# ─── Configuration ───────────────────────────────────────────────────────────

GATE_PIDFILE="/var/run/zlar-oc-gate.pid"
WATCHDOG_PIDFILE="/var/run/zlar-oc-watchdog.pid"
AUDIT_FILE="/var/log/zlar-oc/audit.jsonl"
WATCHDOG_LOG="/var/log/zlar-oc/watchdog.log"
GATE_BIN="/usr/local/bin/zlar-oc-gate"

CHECK_INTERVAL=10        # seconds between gate health checks
MAX_RESTART_ATTEMPTS=3   # restarts before lockdown
RESTART_BACKOFF_BASE=2   # exponential backoff base (seconds)
LOCKDOWN_COOLDOWN=300    # seconds before attempting recovery after lockdown

AGENT_USER="aiagent"
HOSTNAME="$(hostname -s)"
SEQ=0

# ─── Helpers ─────────────────────────────────────────────────────────────────

log_wd() { echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] [watchdog] $*" >> "${WATCHDOG_LOG}"; }

next_seq() { SEQ=$((SEQ + 1)); echo "${SEQ}"; }

gen_id() {
    local ts_hex
    ts_hex=$(printf '%012x' "$(date +%s%3N)" 2>/dev/null || printf '%012x' "$(date +%s)000")
    local rand
    rand=$(od -An -tx1 -N10 /dev/urandom | tr -d ' \n')
    echo "${ts_hex:0:8}-${ts_hex:8:4}-7${rand:0:3}-${rand:3:4}-${rand:7:12}"
}

emit_event() {
    local domain="$1" action="$2" outcome="$3" detail="$4"
    local severity="${5:-warn}"
    local id ts seq
    id=$(gen_id); ts=$(date -u +%Y-%m-%dT%H:%M:%SZ); seq=$(next_seq)

    printf '{"id":"%s","ts":"%s","seq":%d,"source":"watchdog","host":"%s","user":"admin","domain":"%s","action":"%s","outcome":"%s","detail":%s,"rule":"","policy_version":"","severity":"%s","agent_id":"system","session_id":"watchdog"}\n' \
        "${id}" "${ts}" "${seq}" "${HOSTNAME}" "${domain}" "${action}" "${outcome}" "${detail}" "${severity}" \
        >> "${AUDIT_FILE}" 2>/dev/null || true
}

# ─── Gate Health Check ───────────────────────────────────────────────────────

gate_is_alive() {
    if [ ! -f "${GATE_PIDFILE}" ]; then
        return 1
    fi

    local pid
    pid=$(cat "${GATE_PIDFILE}" 2>/dev/null || echo "")
    if [ -z "${pid}" ]; then
        return 1
    fi

    # Check if the PID is actually a zlar-oc-gate process
    if kill -0 "${pid}" 2>/dev/null; then
        # Verify it's our process, not a recycled PID
        local cmd
        cmd=$(ps -p "${pid}" -o comm= 2>/dev/null || echo "")
        if [[ "${cmd}" == *"zlar-oc-gate"* ]] || [[ "${cmd}" == *"bash"* ]]; then
            return 0
        fi
        log_wd "PID ${pid} exists but is not gate (comm=${cmd})"
        return 1
    fi

    return 1
}

# ─── Gate Restart ────────────────────────────────────────────────────────────

attempt_restart() {
    local attempt="$1"

    log_wd "Attempting gate restart (attempt ${attempt}/${MAX_RESTART_ATTEMPTS})"
    emit_event "system" "watchdog.restart_attempt" "allow" \
        "$(printf '{"event":"gate_restart","attempt":%d,"max":%d}' "${attempt}" "${MAX_RESTART_ATTEMPTS}")" \
        "warn"

    # Clean up stale pidfile
    rm -f "${GATE_PIDFILE}" 2>/dev/null || true

    # Start gate daemon
    "${GATE_BIN}" start &
    local gate_pid=$!

    # Wait a moment for startup
    sleep 2

    # Check if it's alive
    if gate_is_alive; then
        log_wd "Gate restarted successfully (attempt ${attempt})"
        emit_event "system" "watchdog.restart_success" "allow" \
            "$(printf '{"event":"gate_restarted","attempt":%d}' "${attempt}")" \
            "info"
        return 0
    else
        log_wd "Gate restart failed (attempt ${attempt})"
        return 1
    fi
}

# ─── Lockdown ────────────────────────────────────────────────────────────────
# If the gate cannot be restarted, lock down the agent.
# The agent must not operate without observation.

lockdown() {
    log_wd "LOCKDOWN: Gate daemon unrecoverable after ${MAX_RESTART_ATTEMPTS} attempts"
    emit_event "system" "watchdog.lockdown" "deny" \
        "$(printf '{"event":"lockdown","reason":"gate_unrecoverable","restart_attempts":%d}' "${MAX_RESTART_ATTEMPTS}")" \
        "critical"

    # Kill all agent processes — membrane is down, so agent must stop
    local agent_pids
    agent_pids=$(pgrep -u "${AGENT_USER}" 2>/dev/null || echo "")
    if [ -n "${agent_pids}" ]; then
        log_wd "Killing agent processes: ${agent_pids}"
        kill "${agent_pids}" 2>/dev/null || true
        sleep 2
        # Force kill any survivors
        agent_pids=$(pgrep -u "${AGENT_USER}" 2>/dev/null || echo "")
        if [ -n "${agent_pids}" ]; then
            kill -9 "${agent_pids}" 2>/dev/null || true
        fi
        emit_event "system" "watchdog.agent_killed" "deny" \
            '{"event":"agent_processes_killed","reason":"gate_down"}' "critical"
    fi

    log_wd "Lockdown complete. Agent processes terminated. Cooling down for ${LOCKDOWN_COOLDOWN}s."
}

# ─── Main Loop ───────────────────────────────────────────────────────────────

run_watchdog() {
    if [ "$(whoami)" = "${AGENT_USER}" ]; then
        echo "FATAL: Watchdog must NOT run as ${AGENT_USER}." >&2
        exit 1
    fi

    trap 'log_wd "Watchdog shutting down"; rm -f "${WATCHDOG_PIDFILE}"; exit 0' EXIT INT TERM
    echo $$ > "${WATCHDOG_PIDFILE}"
    log_wd "Watchdog started (PID $$, interval=${CHECK_INTERVAL}s, max_retries=${MAX_RESTART_ATTEMPTS})"

    emit_event "system" "watchdog.start" "allow" \
        "$(printf '{"event":"watchdog_start","pid":%d,"interval":%d}' $$ "${CHECK_INTERVAL}")" \
        "info"

    local consecutive_failures=0
    local in_lockdown="false"

    while true; do
        sleep "${CHECK_INTERVAL}"

        if gate_is_alive; then
            if [ ${consecutive_failures} -gt 0 ]; then
                log_wd "Gate recovered (was failing for ${consecutive_failures} checks)"
            fi
            consecutive_failures=0
            in_lockdown="false"
            continue
        fi

        # Gate is not alive
        consecutive_failures=$((consecutive_failures + 1))

        if [ "${in_lockdown}" = "true" ]; then
            # In lockdown — try recovery periodically
            if [ $((consecutive_failures % (LOCKDOWN_COOLDOWN / CHECK_INTERVAL))) -eq 0 ]; then
                log_wd "Lockdown recovery attempt"
                if attempt_restart 1; then
                    in_lockdown="false"
                    consecutive_failures=0
                    emit_event "system" "watchdog.lockdown_recovered" "allow" \
                        '{"event":"lockdown_recovered"}' "warn"
                fi
            fi
            continue
        fi

        log_wd "Gate not alive (failure #${consecutive_failures})"
        emit_event "system" "watchdog.gate_down" "deny" \
            "$(printf '{"event":"gate_down","consecutive_failures":%d}' "${consecutive_failures}")" \
            "warn"

        # Attempt restart with exponential backoff
        local attempt=1
        local restarted="false"
        while [ "${attempt}" -le "${MAX_RESTART_ATTEMPTS}" ]; do
            if attempt_restart "${attempt}"; then
                restarted="true"
                consecutive_failures=0
                break
            fi
            local backoff=$((RESTART_BACKOFF_BASE ** attempt))
            log_wd "Backing off ${backoff}s before next attempt"
            sleep "${backoff}"
            attempt=$((attempt + 1))
        done

        if [ "${restarted}" = "false" ]; then
            lockdown
            in_lockdown="true"
        fi
    done
}

# ─── Status ──────────────────────────────────────────────────────────────────

show_status() {
    echo "ZLAR-OC Watchdog Status"
    echo ""

    # Watchdog status
    if [ -f "${WATCHDOG_PIDFILE}" ]; then
        local wd_pid
        wd_pid=$(cat "${WATCHDOG_PIDFILE}")
        if kill -0 "${wd_pid}" 2>/dev/null; then
            echo "  Watchdog: RUNNING (PID ${wd_pid})"
        else
            echo "  Watchdog: DEAD (stale pidfile)"
        fi
    else
        echo "  Watchdog: NOT RUNNING"
    fi

    # Gate status
    if gate_is_alive; then
        local gate_pid
        gate_pid=$(cat "${GATE_PIDFILE}")
        echo "  Gate:     RUNNING (PID ${gate_pid})"
    else
        echo "  Gate:     DOWN"
    fi

    # Recent watchdog events
    if [ -f "${AUDIT_FILE}" ]; then
        local wd_events
        wd_events=$(grep '"source":"watchdog"' "${AUDIT_FILE}" 2>/dev/null | tail -5)
        if [ -n "${wd_events}" ]; then
            echo ""
            echo "  Recent watchdog events:"
            echo "${wd_events}" | while IFS= read -r line; do
                local ts action severity
                ts=$(echo "${line}" | grep -o '"ts":"[^"]*"' | cut -d'"' -f4)
                action=$(echo "${line}" | grep -o '"action":"[^"]*"' | cut -d'"' -f4)
                severity=$(echo "${line}" | grep -o '"severity":"[^"]*"' | cut -d'"' -f4)
                echo "    ${ts}  ${action}  [${severity}]"
            done
        fi
    fi
}

stop_watchdog() {
    if [ -f "${WATCHDOG_PIDFILE}" ]; then
        local pid
        pid=$(cat "${WATCHDOG_PIDFILE}")
        if kill -0 "${pid}" 2>/dev/null; then
            kill "${pid}"
            echo "Watchdog stopped (PID ${pid})"
        else
            echo "Watchdog not running (stale pidfile)"
            rm -f "${WATCHDOG_PIDFILE}"
        fi
    else
        echo "Watchdog not running"
    fi
}

# ─── Argument Parsing ────────────────────────────────────────────────────────

ACTION="${1:-help}"
shift || true

while [ $# -gt 0 ]; do
    case "$1" in
        --interval)     shift; CHECK_INTERVAL="$1"; shift ;;
        --max-retries)  shift; MAX_RESTART_ATTEMPTS="$1"; shift ;;
        --gate-bin)     shift; GATE_BIN="$1"; shift ;;
        --gate-pidfile) shift; GATE_PIDFILE="$1"; shift ;;
        --audit)        shift; AUDIT_FILE="$1"; shift ;;
        *)              shift ;;
    esac
done

case "${ACTION}" in
    start)   run_watchdog ;;
    stop)    stop_watchdog ;;
    status)  show_status ;;
    *)
        echo "Usage: $0 {start|stop|status} [--interval SECS] [--max-retries N] [--gate-bin PATH]"
        echo ""
        echo "Membrane self-repair daemon. Monitors gate, restarts on failure,"
        echo "locks down agent if gate is unrecoverable."
        exit 1
        ;;
esac
