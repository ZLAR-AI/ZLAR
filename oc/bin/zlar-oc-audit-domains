#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
# ZLAR-OC Audit Domains
#
# Extracts unique HTTPS/HTTP destination domains from the audit trail.
# Used during Phase A (observe) to build the HTTPS allowlist for Phase B.
#
# Usage:
#   zlar-oc-audit-domains                          # All time
#   zlar-oc-audit-domains --since 48h              # Last 48 hours
#   zlar-oc-audit-domains --since 48h --format pf  # Output as pf table
#   zlar-oc-audit-domains --since 48h --format csv # Output as CSV with counts
#
# Reads from: /var/log/zlar-oc/audit.jsonl (or --audit FILE)
# ═══════════════════════════════════════════════════════════════════════════════

set -euo pipefail

AUDIT_FILE="/var/log/zlar-oc/audit.jsonl"
SINCE=""
FORMAT="table"  # table, pf, csv, json
KNOWN_HOSTS_FILE=""

# Colors
if [ -t 1 ]; then
    GREEN='\033[0;32m'; YELLOW='\033[0;33m'
    BOLD='\033[1m'; NC='\033[0m'
else
    GREEN=''; YELLOW=''; BOLD=''; NC=''
fi

# ─── Argument Parsing ────────────────────────────────────────────────────────

while [ $# -gt 0 ]; do
    case "$1" in
        --audit)    shift; AUDIT_FILE="$1"; shift ;;
        --since)    shift; SINCE="$1"; shift ;;
        --format)   shift; FORMAT="$1"; shift ;;
        --known)    shift; KNOWN_HOSTS_FILE="$1"; shift ;;
        --help|-h)
            echo "Usage: $0 [--since DURATION] [--format table|pf|csv|json] [--audit FILE] [--known FILE]"
            echo ""
            echo "Options:"
            echo "  --since DURATION   Only include events from the last DURATION"
            echo "                     Examples: 48h, 24h, 7d, 1h"
            echo "  --format FORMAT    Output format:"
            echo "                       table  Human-readable table (default)"
            echo "                       pf     pf table file (one IP/host per line)"
            echo "                       csv    CSV with domain, IP, count, first/last seen"
            echo "                       json   JSON array of domain objects"
            echo "  --audit FILE       Audit trail file (default: /var/log/zlar-oc/audit.jsonl)"
            echo "  --known FILE       File of known-good hosts (one per line) to mark in output"
            echo ""
            echo "Phase A → B workflow:"
            echo "  1. Run ZLAR-OC in Phase A for 48h"
            echo "  2. $0 --since 48h --format table"
            echo "  3. Review domains, remove anything suspicious"
            echo "  4. $0 --since 48h --format pf > /usr/local/etc/zlar-oc/pf-rules/https-allowlist.txt"
            echo "  5. Edit pf rules: comment Phase A, uncomment Phase B"
            echo "  6. sudo pfctl -f /etc/pf.conf"
            exit 0
            ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
done

if [ ! -f "${AUDIT_FILE}" ]; then
    echo "Audit file not found: ${AUDIT_FILE}" >&2
    echo "Is the gate daemon running? Check: zlar-oc-launch --status" >&2
    exit 1
fi

if ! command -v jq &>/dev/null; then
    echo "jq is required. Install with: brew install jq / apt install jq" >&2
    exit 1
fi

# ─── Time Filter ─────────────────────────────────────────────────────────────

compute_cutoff() {
    local duration="$1"
    local value="${duration%[hHdDmM]}"
    local unit="${duration##*[0-9]}"

    local seconds=0
    case "${unit}" in
        h|H) seconds=$((value * 3600)) ;;
        d|D) seconds=$((value * 86400)) ;;
        m|M) seconds=$((value * 60)) ;;
        *)   seconds=$((value * 3600)) ;;  # Default to hours
    esac

    local now
    now=$(date +%s)
    local cutoff=$((now - seconds))

    # Return as ISO 8601
    if date -u -r "${cutoff}" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null; then
        return
    fi
    # Linux fallback
    date -u -d "@${cutoff}" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "1970-01-01T00:00:00Z"
}

# ─── Load Known Hosts ────────────────────────────────────────────────────────

declare -A KNOWN_HOSTS=()
if [ -n "${KNOWN_HOSTS_FILE}" ] && [ -f "${KNOWN_HOSTS_FILE}" ]; then
    while IFS= read -r line; do
        line=$(echo "${line}" | sed 's/#.*//' | tr -d '[:space:]')
        if [ -n "${line}" ]; then
            KNOWN_HOSTS["${line}"]=1
        fi
    done < "${KNOWN_HOSTS_FILE}"
fi

# Default known-good hosts (from R021 in the policy)
DEFAULT_KNOWN=(
    "api.anthropic.com"
    "api.openai.com"
    "huggingface.co"
    "cdn-lfs.huggingface.co"
    "github.com"
    "api.github.com"
)
for h in "${DEFAULT_KNOWN[@]}"; do
    KNOWN_HOSTS["${h}"]=1
done

# ─── Extract Domains ─────────────────────────────────────────────────────────

extract_domains() {
    local filter="."

    # Filter by time if --since specified
    if [ -n "${SINCE}" ]; then
        local cutoff
        cutoff=$(compute_cutoff "${SINCE}")
        filter="select(.ts >= \"${cutoff}\")"
    fi

    # Extract outbound network events with HTTPS/HTTP ports
    jq -r "
        ${filter} |
        select(.domain == \"net.outbound\" or .domain == \"net.http\") |
        select(.detail != null) |
        .detail |
        {
            dst_host: (.dst_host // .host // \"\"),
            dst_ip: (.dst_ip // .ip // \"\"),
            dst_port: (.dst_port // .port // 0)
        } |
        select(.dst_port == 443 or .dst_port == 80) |
        [.dst_host, .dst_ip, (.dst_port | tostring)] | join(\"\t\")
    " "${AUDIT_FILE}" 2>/dev/null | sort | uniq -c | sort -rn
}

# Also extract from pf log events (pflog captures IP, not hostname)
extract_pf_domains() {
    local filter="."

    if [ -n "${SINCE}" ]; then
        local cutoff
        cutoff=$(compute_cutoff "${SINCE}")
        filter="select(.ts >= \"${cutoff}\")"
    fi

    # pf events have dst_ip but not dst_host — we'll reverse-resolve later
    jq -r "
        ${filter} |
        select(.source == \"pf\" or (.domain == \"net.outbound\" and .detail.blocked_by == \"pf\")) |
        select(.detail != null) |
        .detail |
        [(.dst_ip // \"\"), (.dst_port // 0 | tostring)] | join(\"\t\")
    " "${AUDIT_FILE}" 2>/dev/null | sort | uniq -c | sort -rn
}

# ─── Reverse DNS ─────────────────────────────────────────────────────────────

reverse_lookup() {
    local ip="$1"
    if [ -z "${ip}" ] || [ "${ip}" = "" ]; then
        echo ""
        return
    fi
    # Try reverse DNS
    local hostname
    hostname=$(dig +short -x "${ip}" 2>/dev/null | head -1 | sed 's/\.$//')
    if [ -n "${hostname}" ]; then
        echo "${hostname}"
    else
        echo "${ip}"
    fi
}

# ─── Output Formatters ──────────────────────────────────────────────────────

output_table() {
    echo -e "${BOLD}ZLAR-OC HTTPS Egress Domains${NC}"
    if [ -n "${SINCE}" ]; then
        echo -e "  Period: last ${SINCE}"
    else
        echo -e "  Period: all time"
    fi
    echo -e "  Source: ${AUDIT_FILE}"
    echo ""

    printf "  ${BOLD}%-6s  %-40s  %-20s  %-6s  %s${NC}\n" "COUNT" "HOST" "IP" "PORT" "STATUS"
    printf "  %-6s  %-40s  %-20s  %-6s  %s\n" "─────" "────────────────────────────────────────" "────────────────────" "──────" "──────"

    local total=0
    local known_count=0
    local unknown_count=0

    while IFS=$'\t' read -r count host ip port; do
        # Trim whitespace from count
        count=$(echo "${count}" | tr -d '[:space:]')
        total=$((total + count))

        local display_host="${host}"
        if [ -z "${display_host}" ] || [ "${display_host}" = "" ]; then
            display_host="${ip}"
        fi

        local status=""
        if [ -n "${display_host}" ] && [ -n "${KNOWN_HOSTS[${display_host}]+_}" ]; then
            status="${GREEN}known${NC}"
            known_count=$((known_count + 1))
        else
            status="${YELLOW}NEW${NC}"
            unknown_count=$((unknown_count + 1))
        fi

        printf "  %-6s  %-40s  %-20s  %-6s  " "${count}" "${display_host}" "${ip}" "${port}"
        echo -e "${status}"
    done < <(extract_domains)

    echo ""
    echo -e "  ${BOLD}Summary:${NC} ${total} connections, ${known_count} known hosts, ${unknown_count} new hosts"

    if [ ${unknown_count} -gt 0 ]; then
        echo ""
        echo -e "  ${YELLOW}Review the NEW hosts above before transitioning to Phase B.${NC}"
        echo "  To generate the pf allowlist: $0 --since ${SINCE:-all} --format pf"
    else
        echo ""
        echo -e "  ${GREEN}All observed hosts are in the known-good list.${NC}"
        echo "  Safe to transition to Phase B."
    fi
}

output_pf() {
    # Output one IP/hostname per line, suitable for pf table file
    echo "# ZLAR-OC HTTPS Allowlist"
    echo "# Generated: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    if [ -n "${SINCE}" ]; then
        echo "# Observation period: last ${SINCE}"
    fi
    echo "# Source: ${AUDIT_FILE}"
    echo "#"
    echo "# Load with: table <allowed_https_hosts> persist file \"this-file.txt\""
    echo ""

    # Collect unique IPs from audit events
    local _seen_ips=""

    while IFS=$'\t' read -r count host ip port; do
        if [ -n "${ip}" ] && [ "${ip}" != "" ]; then
            echo "${ip}    # ${host} (${count} connections)"
        elif [ -n "${host}" ] && [ "${host}" != "" ]; then
            # Resolve hostname to IP for pf
            local resolved
            resolved=$(dig +short "${host}" 2>/dev/null | head -1)
            if [ -n "${resolved}" ]; then
                echo "${resolved}    # ${host} (${count} connections)"
            else
                echo "# UNRESOLVED: ${host} (${count} connections)"
            fi
        fi
    done < <(extract_domains)
}

output_csv() {
    echo "count,host,ip,port,known"

    while IFS=$'\t' read -r count host ip port; do
        count=$(echo "${count}" | tr -d '[:space:]')
        local display_host="${host}"
        if [ -z "${display_host}" ]; then display_host="${ip}"; fi

        local known="false"
        if [ -n "${display_host}" ] && [ -n "${KNOWN_HOSTS[${display_host}]+_}" ]; then
            known="true"
        fi

        echo "${count},${display_host},${ip},${port},${known}"
    done < <(extract_domains)
}

output_json() {
    echo "["
    local first="true"

    while IFS=$'\t' read -r count host ip port; do
        count=$(echo "${count}" | tr -d '[:space:]')
        local display_host="${host}"
        if [ -z "${display_host}" ]; then display_host="${ip}"; fi

        local known="false"
        if [ -n "${display_host}" ] && [ -n "${KNOWN_HOSTS[${display_host}]+_}" ]; then
            known="true"
        fi

        if [ "${first}" = "true" ]; then
            first="false"
        else
            echo ","
        fi
        printf '  {"host":"%s","ip":"%s","port":%s,"count":%s,"known":%s}' \
            "${display_host}" "${ip}" "${port}" "${count}" "${known}"
    done < <(extract_domains)

    echo ""
    echo "]"
}

# ─── Main ────────────────────────────────────────────────────────────────────

case "${FORMAT}" in
    table)  output_table ;;
    pf)     output_pf ;;
    csv)    output_csv ;;
    json)   output_json ;;
    *)
        echo "Unknown format: ${FORMAT}" >&2
        echo "Valid formats: table, pf, csv, json" >&2
        exit 1
        ;;
esac
