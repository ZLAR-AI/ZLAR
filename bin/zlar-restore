#!/bin/bash
# zlar-restore — Agent Health CLI
#
# Commands:
#   evaluate [--session <id>]  Run all detectors against a session trace
#   status                     Show current trust state
#   reset <reason>             Reset trust state to healthy (with friction)
#   history                    Show trust state transition history
#   detectors                  List available detectors
#
# The restore CLI is the human interface to the Agent Health subsystem.
# It reads the audit trail, runs detectors, and manages trust state.
# It does NOT modify gate behavior directly — it writes trust state
# files that lib/restore.sh reads on the next gate invocation.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

RESTORE_CONFIG="${PROJECT_DIR}/etc/restore-config.json"
AUDIT_FILE="${PROJECT_DIR}/var/log/audit.jsonl"

# ── Configuration ─────────────────────────────────────────────────────────────

load_config() {
    if [ ! -f "${RESTORE_CONFIG}" ]; then
        echo "Error: ${RESTORE_CONFIG} not found" >&2
        exit 1
    fi

    TRUST_STATE_PATH=$(jq -r '.trust_state_file // "var/restore/trust-state.json"' "${RESTORE_CONFIG}" 2>/dev/null)
    TRUST_STATE_FILE="${PROJECT_DIR}/${TRUST_STATE_PATH}"
    RESET_DELAY_S=$(jq -r '.reset.delay_s // 30' "${RESTORE_CONFIG}" 2>/dev/null)
    RESET_REQUIRE_REASON=$(jq -r '.reset.require_reason // true' "${RESTORE_CONFIG}" 2>/dev/null)
    MAX_RESETS_PER_DAY=$(jq -r '.reset.max_resets_per_day // 3' "${RESTORE_CONFIG}" 2>/dev/null)

    # HMAC key path for trust-state integrity
    HMAC_KEY_FILE=""
    local _hmac_path
    _hmac_path=$(jq -r '.hmac_key_file // ""' "${RESTORE_CONFIG}" 2>/dev/null)
    if [ -n "${_hmac_path}" ] && [ -f "${PROJECT_DIR}/${_hmac_path}" ]; then
        HMAC_KEY_FILE="${PROJECT_DIR}/${_hmac_path}"
    fi

    mkdir -p "$(dirname "${TRUST_STATE_FILE}")" 2>/dev/null || true
}

# ── Privacy invariant ─────────────────────────────────────────────────────────

require_enabled() {
    local _enabled
    _enabled=$(jq -r '.enabled // false' "${RESTORE_CONFIG}" 2>/dev/null || echo "false")
    if [ "${_enabled}" != "true" ]; then
        echo "Agent Health is not enabled." >&2
        echo "Run: zlar health on" >&2
        exit 1
    fi
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_evaluate() {
    require_enabled

    local session_id=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --session) session_id="$2"; shift 2 ;;
            *) echo "Unknown option: $1" >&2; exit 1 ;;
        esac
    done

    if [ ! -f "${AUDIT_FILE}" ]; then
        echo "No audit trail found at ${AUDIT_FILE}"
        echo "Trust state: healthy (no data)"
        exit 0
    fi

    # Run the Node.js engine with bounded trace extraction
    local result
    result=$(ZLAR_SESSION_ID="${session_id}" node -e "
        import { evaluate } from '${PROJECT_DIR}/packages/zlar-restore/restore-engine.mjs';
        import { readFileSync, openSync, fstatSync, readSync, closeSync } from 'node:fs';

        // Bounded reverse-read (same as restore-trigger.mjs)
        function readTrace(path, sid, max) {
            const CHUNK = 64 * 1024;
            const trace = [];
            try {
                const fd = openSync(path, 'r');
                const stat = fstatSync(fd);
                let pos = stat.size;
                let rem = '';
                while (pos > 0 && trace.length < max) {
                    const sz = Math.min(CHUNK, pos);
                    pos -= sz;
                    const buf = Buffer.alloc(sz);
                    readSync(fd, buf, 0, sz, pos);
                    const chunk = buf.toString('utf-8') + rem;
                    const lines = chunk.split('\\n');
                    rem = lines.shift() || '';
                    for (let i = lines.length - 1; i >= 0; i--) {
                        const ln = lines[i].trim();
                        if (!ln) continue;
                        try {
                            const ev = JSON.parse(ln);
                            if ((!sid || ev.session_id === sid) && ev.seq === 1) {
                                trace.push(ev);
                                if (trace.length >= max) break;
                            }
                        } catch {}
                    }
                }
                if (rem.trim() && trace.length < max) {
                    try {
                        const ev = JSON.parse(rem.trim());
                        if ((!sid || ev.session_id === sid) && ev.seq === 1) trace.push(ev);
                    } catch {}
                }
                closeSync(fd);
            } catch {}
            trace.reverse();
            return trace;
        }

        const trace = readTrace('${AUDIT_FILE}', process.env.ZLAR_SESSION_ID || null, 500);
        const result = await evaluate(trace);
        console.log(JSON.stringify(result, null, 2));
    " 2>/dev/null)

    if [ -z "${result}" ]; then
        echo "Error: evaluation failed" >&2
        exit 1
    fi

    local recommendation
    recommendation=$(echo "${result}" | jq -r '.recommendation')
    local effective_score
    effective_score=$(echo "${result}" | jq -r '.aggregate.effective')
    local dominant_score
    dominant_score=$(echo "${result}" | jq -r '.aggregate.dominant')
    local diffuse_score
    diffuse_score=$(echo "${result}" | jq -r '.aggregate.diffuse_weighted')
    local trace_length
    trace_length=$(echo "${result}" | jq -r '.trace_length')
    local primary_detector
    primary_detector=$(echo "${result}" | jq -r '.primary_detector // "none"')

    echo "Agent Health Evaluation"
    echo "======================"
    echo "  Recommendation: ${recommendation}"
    echo "  Effective score: ${effective_score} (dominant=${dominant_score}, diffuse=${diffuse_score})"
    echo "  Primary signal: ${primary_detector}"
    echo "  Trace length: ${trace_length} events"
    echo
    echo "Detector Results:"
    echo "${result}" | jq -r '.detectors | to_entries[] | "  \(.key): score=\(.value.score) confidence=\(.value.confidence) evidence=\(.value.evidence_count)"'

    # Apply trust state transition if recommendation is worse than current
    if [ "${recommendation}" != "healthy" ]; then
        local current_state="healthy"
        if [ -f "${TRUST_STATE_FILE}" ]; then
            current_state=$(jq -r '.state // "healthy"' "${TRUST_STATE_FILE}" 2>/dev/null || echo "healthy")
        fi

        echo
        echo "Current trust state: ${current_state}"
        echo "Recommended state: ${recommendation}"

        # Apply via Node.js trust-state machine (monotone check)
        local transition_result
        transition_result=$(node -e "
            import { setHmacKey, loadTrustState, proposeTransition, applyTransition, saveTrustState } from '${PROJECT_DIR}/packages/zlar-restore/trust-state.mjs';
            if ('${HMAC_KEY_FILE}') setHmacKey('${HMAC_KEY_FILE}');
            const state = loadTrustState('${TRUST_STATE_FILE}');
            const transition = proposeTransition(state.state, '${recommendation}', 'cli:evaluate');
            if (transition.accepted) {
                const updated = applyTransition(state, transition);
                saveTrustState('${TRUST_STATE_FILE}', updated);
                console.log('TRANSITIONED: ' + transition.from + ' -> ' + transition.to);
            } else {
                console.log('NO_CHANGE: ' + transition.reason);
            }
        " 2>/dev/null)

        echo "  ${transition_result}"
    fi
}

cmd_status() {
    require_enabled

    if [ ! -f "${TRUST_STATE_FILE}" ]; then
        echo "Trust state: healthy (no state file)"
        exit 0
    fi

    local state
    state=$(jq -r '.state // "unknown"' "${TRUST_STATE_FILE}" 2>/dev/null)
    local updated_at
    updated_at=$(jq -r '.updated_at // "never"' "${TRUST_STATE_FILE}" 2>/dev/null)
    local reset_count
    reset_count=$(jq -r '.reset_count // 0' "${TRUST_STATE_FILE}" 2>/dev/null)
    local history_count
    history_count=$(jq '.history | length' "${TRUST_STATE_FILE}" 2>/dev/null || echo 0)

    echo "Agent Health Status"
    echo "==================="
    echo "  Trust state: ${state}"
    echo "  Last updated: ${updated_at}"
    echo "  Reset count: ${reset_count}"
    echo "  History entries: ${history_count}"
}

cmd_reset() {
    require_enabled

    local reason="$*"

    if [ "${RESET_REQUIRE_REASON}" = "true" ] && [ -z "${reason}" ]; then
        echo "Error: reset requires a reason" >&2
        echo "Usage: zlar-restore reset <reason>" >&2
        exit 1
    fi

    # Check daily reset limit
    local today
    today=$(date -u +%Y-%m-%d)
    local today_resets=0
    if [ -f "${TRUST_STATE_FILE}" ]; then
        today_resets=$(jq --arg d "${today}" '[.history[] | select(.source == "operator_reset" and (.at | startswith($d)))] | length' "${TRUST_STATE_FILE}" 2>/dev/null || echo 0)
    fi

    if [ "${today_resets}" -ge "${MAX_RESETS_PER_DAY}" ]; then
        echo "Error: daily reset limit reached (${MAX_RESETS_PER_DAY})" >&2
        exit 1
    fi

    local current_state="healthy"
    if [ -f "${TRUST_STATE_FILE}" ]; then
        current_state=$(jq -r '.state // "healthy"' "${TRUST_STATE_FILE}" 2>/dev/null || echo "healthy")
    fi

    if [ "${current_state}" = "healthy" ]; then
        echo "Trust state is already healthy. Nothing to reset."
        exit 0
    fi

    # Friction: delay
    echo "Resetting trust state from ${current_state} to healthy."
    echo "Reason: ${reason}"
    echo "Waiting ${RESET_DELAY_S}s (friction delay)..."
    sleep "${RESET_DELAY_S}"

    # Apply reset via Node.js trust-state machine
    ZLAR_RESET_REASON="${reason}" ZLAR_RESET_USER="$(whoami)" node -e "
        import { setHmacKey, loadTrustState, resetTrustState, saveTrustState } from '${PROJECT_DIR}/packages/zlar-restore/trust-state.mjs';
        if ('${HMAC_KEY_FILE}') setHmacKey('${HMAC_KEY_FILE}');
        const state = loadTrustState('${TRUST_STATE_FILE}');
        const result = resetTrustState(state, process.env.ZLAR_RESET_REASON, process.env.ZLAR_RESET_USER);
        if (result.accepted) {
            saveTrustState('${TRUST_STATE_FILE}', result.trustState);
            console.log('Trust state reset to healthy. Reset count: ' + result.trustState.reset_count);
        } else {
            console.error('Reset failed: ' + result.reason);
            process.exit(1);
        }
    " 2>/dev/null

    echo "Reset complete."
}

cmd_history() {
    require_enabled

    if [ ! -f "${TRUST_STATE_FILE}" ]; then
        echo "No trust state history (no state file)"
        exit 0
    fi

    echo "Trust State History"
    echo "==================="
    jq -r '.history[] | "\(.at)  \(.from) -> \(.to)  [\(.source)]  \(.reason // "")"' "${TRUST_STATE_FILE}" 2>/dev/null
}

cmd_sign_config() {
    local hmac_key_file="${PROJECT_DIR}/etc/keys/restore-config-hmac.key"

    if [ ! -f "${hmac_key_file}" ]; then
        echo "No config HMAC key found at ${hmac_key_file}" >&2
        echo "Generate one: openssl rand -hex 32 > ${hmac_key_file}" >&2
        exit 1
    fi

    node -e "
        import { signConfig } from '${PROJECT_DIR}/packages/zlar-restore/config-integrity.mjs';
        import { readFileSync } from 'node:fs';
        const key = readFileSync('${hmac_key_file}', 'utf-8').trim();
        const hmac = signConfig('${RESTORE_CONFIG}', key);
        console.log('Config signed. HMAC: ' + hmac.substring(0, 16) + '...');
    " 2>/dev/null

    echo "Sidecar written to ${RESTORE_CONFIG}.hmac"
}

cmd_detectors() {
    echo "Available Detectors"
    echo "==================="
    node -e "
        import { loadDetectors } from '${PROJECT_DIR}/packages/zlar-restore/restore-engine.mjs';
        const detectors = await loadDetectors();
        for (const d of detectors) {
            console.log('  ' + d.id + ': ' + d.description);
        }
    " 2>/dev/null
}

# ── Usage ─────────────────────────────────────────────────────────────────────

usage() {
    cat <<'EOF'
Usage: zlar-restore <command> [options]

Commands:
  evaluate [--session <id>]  Run detectors against session trace
  status                     Show current trust state
  reset <reason>             Reset trust state (requires reason)
  history                    Show state transition history
  detectors                  List available detectors
  sign-config                Sign restore-config.json (run after edits)

Agent Health observes. It does not enforce directly.
EOF
    exit 0
}

# ── Main ──────────────────────────────────────────────────────────────────────

[ $# -eq 0 ] && usage

load_config

case "$1" in
    evaluate) shift; cmd_evaluate "$@" ;;
    status)   cmd_status ;;
    reset)    shift; cmd_reset "$@" ;;
    history)  cmd_history ;;
    detectors) cmd_detectors ;;
    sign-config) cmd_sign_config ;;
    -h|--help) usage ;;
    *) echo "Unknown command: $1" >&2; usage ;;
esac
