#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
# ZLAR Gate v3.0.6 — Claude Code Hook Script
#
# THE gate. Runs synchronously on every Claude Code PreToolUse hook invocation.
# Reads tool call from stdin, classifies, evaluates policy, asks Telegram if
# needed, writes audit trail, returns allow/deny on stdout.
#
# No daemon. No server. No database. The process IS the pending state.
#
# v2.7.x changes:
#   - First Authority Law published as signal/DOCTRINE.md
#   - Structural off-switch at /etc/zlar/off-flag (root-owned, sudoers-toggled)
#   - Architecture map at docs/architecture-map.md
#   - H13 pending_count belt-reset on date rollover
#
# v2.5.1 changes:
#   - Approval binding: approvals are now bound to SHA-256 hash of exact command
#   - Hash chain atomicity via flock on Linux
#   - Strict signed audit mode (ZLAR_REQUIRE_SIGNED_AUDIT)
#
# v2.5.0 changes:
#   - Per-entry Ed25519 signing of audit trail entries (AU-10 non-repudiation)
#   - AUDIT_SIGNING_KEY configuration for audit entry signatures
#   - Graceful fallback to "unsigned" if signing key missing or signing fails
#
# v2.4.0 changes:
#   - 9 new tool translations (TodoWrite, TaskOutput, TaskStop, Skill,
#     EnterPlanMode, ExitPlanMode, AskUserQuestion, EnterWorktree, ExitWorktree)
#   - MCP tool classification (mcp__* → mcp domain)
#   - Internal tool fast-path (no policy evaluation for conversation-internal tools)
#   - denied_by field in deny responses (human/timeout/policy/rate_limit/gate_error)
#   - authorizer field in audit events
#   - ERR trap for crash safety
#   - Newline injection fix (S1 CRITICAL from gate v2 review)
#   - Private temp directory (not world-readable /tmp)
#   - Audit file rotation at 10MB
#   - Atomic session counters via flock
#   - Telegram token not exposed in process table
# ═══════════════════════════════════════════════════════════════════════════════

set -euo pipefail

# ERR trap — if anything fails unexpectedly, deny and log
trap '_gate_crash $LINENO' ERR

_gate_crash() {
    local line="$1"
    local crash_log="${LOG_FILE:-}"
    [ -z "${crash_log}" ] && crash_log="${PROJECT_DIR:+${PROJECT_DIR}/var/log/gate-crash.log}"
    [ -z "${crash_log}" ] && crash_log="/var/log/zlar-gate-crash.log"
    echo "[$(date -u +%Y-%m-%dT%H:%M:%SZ)] CRASH at line ${line}" >> "${crash_log}" 2>/dev/null || true
    # Emit correct event type — _GATE_HOOK_EVENT is set when we know the hook type.
    # Default to PreToolUse if crash happens before hook type is determined.
    local _event="${_GATE_HOOK_EVENT:-PreToolUse}"
    echo '{"hookSpecificOutput":{"hookEventName":"'"${_event}"'","permissionDecision":"deny","permissionDecisionReason":"ZLAR gate crash (line '"${line}"'). All actions blocked."}}'
    exit 0
}

# ─── Human Override: First Authority ────────────────────────────────────────
# Root-owned flag file at /etc/zlar/off-flag. Agent cannot write /etc without
# sudo, and R003 denies any bash command containing sudo. This is the
# structural human override path for the CC gate. v2.7.0.
#
# Presence of the flag returns allow for this invocation without any further
# evaluation — no policy load, no invariants, no sourcing, no telemetry.
# The wrapper at ~/.claude/zlar-gate.sh has an equivalent check on its own
# flag path (~/.claude/.gate-disabled). During the v2.7.0 overlap period both
# paths are live; either flag being present means off.
if [ -f /etc/zlar/off-flag ]; then
    INPUT=$(cat <&0 2>/dev/null || echo '{}')
    EVENT_NAME=$(echo "${INPUT}" | jq -r '.hook_event_name // "PreToolUse"' 2>/dev/null)
    [ -z "${EVENT_NAME}" ] && EVENT_NAME="PreToolUse"
    printf '{"hookSpecificOutput":{"hookEventName":"%s","permissionDecision":"allow"}}\n' "${EVENT_NAME}"
    exit 0
fi

# ─── Human Lock: Intentional Fail-Closed ──────────────────────────────────────
# User-set flag at ~/.claude/.gate-locked. Set by 'zlar lock' before stepping
# away. Differs from 'zlar off' (which allows everything) — lock denies
# everything with no Telegram routing. The agent cannot act at all until
# 'zlar unlock' is run. No sudo required; any human at the keyboard can set it.
#
# Checked after off-flag: if the human explicitly turned the gate off, lock
# does not override that (off means maintenance mode, not governance). If both
# are set, off wins — the human present at the keyboard chose that state.
if [ -f "${HOME}/.claude/.gate-locked" ]; then
    INPUT=$(cat <&0 2>/dev/null || echo '{}')
    EVENT_NAME=$(echo "${INPUT}" | jq -r '.hook_event_name // "PreToolUse"' 2>/dev/null)
    [ -z "${EVENT_NAME}" ] && EVENT_NAME="PreToolUse"
    LOCKED_AT=$(cat "${HOME}/.claude/.gate-locked" 2>/dev/null | tr -d '[:space:]')
    printf '{"hookSpecificOutput":{"hookEventName":"%s","permissionDecision":"deny","permissionDecisionReason":"[gate:locked] Gate locked by human at %s. Run '\''zlar unlock'\'' to resume."}}\n' \
        "${EVENT_NAME}" "${LOCKED_AT:-unknown}"
    exit 0
fi

# Set when hook event type is determined (before main processing).
_GATE_HOOK_EVENT="PreToolUse"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "${SCRIPT_DIR}")"

# Source cryptographic abstraction layer
export _CRYPTO_PROJECT_DIR="${PROJECT_DIR}"
# shellcheck source=../lib/crypto.sh
source "${PROJECT_DIR}/lib/crypto.sh"

# Source human invariant enforcement (H6, H13, H14, H15, H17)
export _HI_PROJECT_DIR="${PROJECT_DIR}"
# shellcheck source=../lib/human-invariants.sh
source "${PROJECT_DIR}/lib/human-invariants.sh"

# Source gate uptime tracking (v3.1.4). Heartbeat runs on every gate
# invocation while the gate is ON — writes batched to avoid hot-path cost.
# Off-flag / lock paths have already exited above; reaching this point
# means the gate is effectively on.
export _GU_PROJECT_DIR="${PROJECT_DIR}"
# shellcheck source=../lib/gate-uptime.sh
source "${PROJECT_DIR}/lib/gate-uptime.sh"
gu_record_heartbeat 2>/dev/null || true

# Source fail-closed alert library — out-of-band notification path that
# fires when a human invariant blocks an ask. Independent of the gate's
# normal ask flow, so it cannot be blocked by the same invariant it is
# alerting about. Best-effort and silent on failure.
# shellcheck source=../lib/fail-closed-alert.sh
source "${PROJECT_DIR}/lib/fail-closed-alert.sh"
# shellcheck source=../lib/preconfirm-cc.sh
source "${PROJECT_DIR}/lib/preconfirm-cc.sh"

# ─── Private temp directory ──────────────────────────────────────────────────
# Not /tmp (world-readable). Gate-private directory for policy verification.
GATE_TMP="${PROJECT_DIR}/var/tmp"
mkdir -p "${GATE_TMP}" 2>/dev/null
chmod 700 "${GATE_TMP}" 2>/dev/null || true

# ─── Configuration ──────────────────────────────────────────────────────────

GATE_CONFIG="${PROJECT_DIR}/etc/gate.json"
POLICY_FILE="${PROJECT_DIR}/etc/policies/active.policy.json"
POLICY_PUBKEY="${PROJECT_DIR}/etc/keys/policy-signing.pub"

# ── Second Authority Law: Constitution ─────────────────────────────────────
CONSTITUTION_FILE="${PROJECT_DIR}/etc/constitution.json"
CONSTITUTION_PUBKEY="${PROJECT_DIR}/etc/keys/constitution-signing.pub"
CONSTITUTION_PRESENCE_FILE="${PROJECT_DIR}/var/log/.constitution-last-hash"
_CONSTITUTION_VALIDATED=""
AUDIT_SIGNING_KEY="${HOME}/.zlar-signing.key"
ZLAR_REQUIRE_SIGNED_AUDIT="${ZLAR_REQUIRE_SIGNED_AUDIT:-false}"
AUDIT_FILE="${PROJECT_DIR}/var/log/audit.jsonl"
ZLAR_EMIT_RECEIPTS="${ZLAR_EMIT_RECEIPTS:-false}"
RECEIPT_FILE="${PROJECT_DIR}/var/log/receipts.jsonl"
_PREV_RECEIPT_HASH=""
AVAILABILITY_STATE="${PROJECT_DIR}/var/log/availability.state"
AWAY_QUEUE="${PROJECT_DIR}/var/log/away-queue.jsonl"
LOCKDOWN_FILE="${PROJECT_DIR}/var/log/watchdog.lock"

# ── Sandbox Configuration ───────────────────────────────────────────────────
# Per-command macOS Seatbelt sandboxing (Phase C perimeter closure).
# Two tiers: nonet (default, denies all network) and net (allows network).
SANDBOX_PROFILE_NONET="${PROJECT_DIR}/etc/sandbox/zlar-gate-nonet.sb"
SANDBOX_PROFILE_NET="${PROJECT_DIR}/etc/sandbox/zlar-gate-net.sb"
SANDBOX_ENABLED="false"
if [ -f "${SANDBOX_PROFILE_NONET}" ] && command -v sandbox-exec &>/dev/null; then
    SANDBOX_ENABLED="true"
fi
# Override via gate.json: {"sandbox": {"enabled": false}}
if [ -f "${GATE_CONFIG}" ] && command -v jq &>/dev/null; then
    _sbx=$(jq -r '.sandbox.enabled // ""' "${GATE_CONFIG}" 2>/dev/null)
    [ "${_sbx}" = "false" ] && SANDBOX_ENABLED="false"
fi
# Network-requiring rules: matched rule determines which sandbox tier to use.
# Rules whose commands legitimately need outbound network get Tier 2b (net).
# Only rules where the human has explicitly approved network access get Tier 2b.
# R001 (safe reads) and R018 (open) do NOT need network — if gh needs network,
# it should match R016 and go through Telegram approval.
SANDBOX_NET_RULES="R014|R014a|R016"
SESSION_DIR="${PROJECT_DIR}/var/log/sessions"
LOG_FILE="${PROJECT_DIR}/var/log/gate.log"

# ─── Cryptographic Metadata (PQC Phase 1) ────────────────────────────────────
# Label every audit entry with the algorithms used. When migration to ML-DSA
# happens, tooling reads these fields to know which entries need re-signing.
# Algorithm labels resolved via lib/crypto.sh abstraction layer.
SIGNATURE_ALGORITHM=$(zlar_crypto_label)
HASH_ALGORITHM=$(zlar_crypto_hash_label)
PUBLIC_KEY_ID="unknown"
if [ -f "${POLICY_PUBKEY}" ]; then
    PUBLIC_KEY_ID=$(zlar_crypto_pubkey_fingerprint "${POLICY_PUBKEY}")
fi

# Load overrides from gate.json if present
if [ -f "${GATE_CONFIG}" ] && command -v jq &>/dev/null; then
    _cfg() { jq -r "$1 // empty" "${GATE_CONFIG}" 2>/dev/null; }
    TELEGRAM_CHAT_ID=$(_cfg '.telegram.chat_id')
    TELEGRAM_TIMEOUT_S=$(_cfg '.telegram.timeout_s')
    AWAY_THRESHOLD=$(_cfg '.availability.away_auto_allow_threshold')
    SESSION_WRITE_LIMIT=$(_cfg '.session_write_limit')
    _req_signed=$(_cfg '.require_signed_audit')
    [ -n "${_req_signed}" ] && ZLAR_REQUIRE_SIGNED_AUDIT="${_req_signed}"
    _emit_receipts=$(_cfg '.emit_receipts')
    [ -n "${_emit_receipts}" ] && ZLAR_EMIT_RECEIPTS="${_emit_receipts}"
fi

# ─── Load Telegram token from .env (parse, don't source) ────────────────────
# Sourcing .env is a code execution vector. Parse key=value only.
_load_env() {
    local env_file="${PROJECT_DIR}/.env"
    if [ -f "${env_file}" ]; then
        while IFS='=' read -r key value; do
            # Skip comments and empty lines
            [[ "${key}" =~ ^[[:space:]]*# ]] && continue
            [[ -z "${key}" ]] && continue
            # Strip surrounding quotes from value
            value="${value%\"}"
            value="${value#\"}"
            value="${value%\'}"
            value="${value#\'}"
            # Only export known keys
            case "${key}" in
                TELEGRAM_BOT_TOKEN|ZLAR_TELEGRAM_TOKEN)
                    export "${key}=${value}"
                    ;;
            esac
        done < "${env_file}"
    fi
}
_load_env

# Source session state library (thin stateful layer for velocity/loop/burst detection)
# shellcheck source=../lib/session-state.sh
if [ -f "${PROJECT_DIR}/lib/session-state.sh" ]; then
    source "${PROJECT_DIR}/lib/session-state.sh"
    SESSION_STATE_ENABLED="true"
else
    SESSION_STATE_ENABLED="false"
fi

# Source restore library (Agent Health trust-state layer)
# shellcheck source=../lib/restore.sh
# RESTORE-INV-04: syntax-check before sourcing. A broken restore.sh must not
# crash the gate. bash -n is a parse-only check (no execution).
if [ -f "${PROJECT_DIR}/lib/restore.sh" ]; then
    if bash -n "${PROJECT_DIR}/lib/restore.sh" 2>/dev/null; then
        source "${PROJECT_DIR}/lib/restore.sh"
        restore_init 2>/dev/null || true  # INV-04: never crash the gate
    else
        echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [gate] WARNING: restore.sh has syntax errors — skipping restore (gate continues without Agent Health)" >> "${PROJECT_DIR}/var/log/gate.log" 2>/dev/null || true
        RESTORE_ENABLED="false"
    fi
fi

# ── Novelty detection ──────────────────────────────────────────────────────
# Tracks which high-consequence domains have been used this session.
# First occurrence of mcp (per server) or webfetch → signal novelty.
# The gate escalates; the human reviews once; subsequent calls proceed normally.
# This is a training moment, not permanent friction.
NOVELTY_DETECTED="false"

novelty_check_and_record() {
    local domain="$1" tool_display="$2"
    local seen_file="${SESSION_DIR}/${SESSION_ID:-unknown}.seen-domains"

    local check_key="${domain}"

    # For MCP, track per server — different servers are different trust surfaces
    if [ "${domain}" = "mcp" ]; then
        local mcp_server
        mcp_server=$(echo "${tool_display}" | sed -n 's/^MCP:\([^/]*\)\/.*/\1/p' 2>/dev/null)
        [ -n "${mcp_server}" ] && check_key="mcp:${mcp_server}"
    fi

    # Only novelty-track high-consequence domains
    case "${domain}" in
        mcp|webfetch) ;;
        *) return 1 ;;
    esac

    # Check if already seen this session
    if [ -f "${seen_file}" ] && grep -qF "${check_key}" "${seen_file}" 2>/dev/null; then
        return 1  # Already seen — not novel
    fi

    # Record and signal novelty
    echo "${check_key}" >> "${seen_file}" 2>/dev/null || true
    return 0  # Novel — first occurrence
}

# Source canary library (governance health probes for human-in-the-loop integrity)
# shellcheck source=../lib/canary.sh
CANARY_LOADED="false"
if [ -f "${PROJECT_DIR}/lib/canary.sh" ]; then
    source "${PROJECT_DIR}/lib/canary.sh"
    canary_load_config "${GATE_CONFIG}"
    CANARY_LOADED="true"
fi

# Load standing approvals (pre-authorized patterns that skip Telegram ask)
STANDING_APPROVALS_LOADED="false"
STANDING_APPROVALS_JSON=""
STANDING_APPROVAL_ID=""
STANDING_APPROVALS_FILE="${PROJECT_DIR}/etc/standing-approvals.json"
if [ -f "${STANDING_APPROVALS_FILE}" ] && command -v jq &>/dev/null; then
    # Verify signature if policy pubkey exists (same trust model as policy)
    _sa_sig_ok="true"
    if [ -f "${POLICY_PUBKEY}" ]; then
        _sa_sig_value=$(jq -r '.signature.value // ""' "${STANDING_APPROVALS_FILE}" 2>/dev/null)
        if [ -z "${_sa_sig_value}" ] || [ "${_sa_sig_value}" = "" ]; then
            _sa_sig_ok="false"
        else
            # Phase B of ADR-011 — dual canonical form verification.
            _sa_canon_spec=$(mktemp "${GATE_TMP}/sa-canon-spec.XXXXXX")
            _sa_canon_pretty=$(mktemp "${GATE_TMP}/sa-canon-pretty.XXXXXX")
            _sa_hash_spec=$(mktemp "${GATE_TMP}/sa-hash-spec.XXXXXX")
            _sa_hash_pretty=$(mktemp "${GATE_TMP}/sa-hash-pretty.XXXXXX")
            _sa_sig_bin=$(mktemp "${GATE_TMP}/sa-sig.XXXXXX")

            jq -S -c '.signature.value = ""' "${STANDING_APPROVALS_FILE}" | tr -d '\n' > "${_sa_canon_spec}" 2>/dev/null
            zlar_crypto_hash "${_sa_canon_spec}" "${_sa_hash_spec}"

            jq '.signature.value = ""' "${STANDING_APPROVALS_FILE}" > "${_sa_canon_pretty}" 2>/dev/null
            zlar_crypto_hash "${_sa_canon_pretty}" "${_sa_hash_pretty}"

            echo "${_sa_sig_value}" | base64 -d > "${_sa_sig_bin}" 2>/dev/null

            if zlar_crypto_verify "${POLICY_PUBKEY}" "${_sa_hash_spec}" "${_sa_sig_bin}" "ed25519"; then
                _sa_sig_ok="true"
            elif zlar_crypto_verify "${POLICY_PUBKEY}" "${_sa_hash_pretty}" "${_sa_sig_bin}" "ed25519"; then
                _sa_sig_ok="true"
                echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [gate] WARN: Standing approvals verified under LEGACY canonical form bash-pretty (ADR-011)" >> "${PROJECT_DIR}/var/log/gate.log" 2>/dev/null || true
            else
                _sa_sig_ok="false"
            fi

            rm -f "${_sa_canon_spec}" "${_sa_canon_pretty}" "${_sa_hash_spec}" "${_sa_hash_pretty}" "${_sa_sig_bin}"
        fi
    fi
    if [ "${_sa_sig_ok}" = "true" ]; then
        STANDING_APPROVALS_JSON=$(jq -c '.approvals // []' "${STANDING_APPROVALS_FILE}" 2>/dev/null)
        STANDING_APPROVALS_LOADED="true"
    fi
fi

# Load agent-policy-bindings (per-agent standing approval scoping + velocity limits)
AGENT_BINDINGS_LOADED="false"
AGENT_BINDINGS_JSON=""
AGENT_BINDINGS_FILE="${PROJECT_DIR}/etc/agent-policy-bindings.json"
if [ -f "${AGENT_BINDINGS_FILE}" ] && command -v jq &>/dev/null; then
    AGENT_BINDINGS_JSON=$(jq -c '.bindings // []' "${AGENT_BINDINGS_FILE}" 2>/dev/null)
    if [ -n "${AGENT_BINDINGS_JSON}" ] && [ "${AGENT_BINDINGS_JSON}" != "[]" ]; then
        AGENT_BINDINGS_LOADED="true"
        # NOTE: log() is not yet defined at module-load time. Use echo to gate log.
        echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [gate] Agent bindings loaded ($(echo "${AGENT_BINDINGS_JSON}" | jq 'length') agents)" >> "${PROJECT_DIR}/var/log/gate.log" 2>/dev/null || true

        # Build A invariant: delegated authority must monotonically narrow, never widen.
        # Validate depth_rules — depth N+1 SAs must be a subset of depth N SAs.
        # NOTE: no 'local' here — this runs at top level, not inside a function.
        _narrowing_ok=$(echo "${AGENT_BINDINGS_JSON}" | jq '
            [.[] | select(.delegation.depth_rules != null) |
                .agent_id as $aid |
                .delegation.depth_rules | sort_by(.depth) |
                . as $rules |
                [range(0; length - 1) |
                    ($rules[.].standing_approvals) as $parent_sas |
                    ($rules[. + 1].standing_approvals) as $child_sas |
                    ($child_sas - $parent_sas) as $widened |
                    select(($widened | length) > 0) |
                    {agent: $aid, depth: $rules[. + 1].depth, widened: $widened}
                ]
            ] | flatten | length
        ' 2>/dev/null || echo "0")
        if [ "${_narrowing_ok}" != "0" ]; then
            echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [gate] WARNING: Delegation depth_rules violate monotonic narrowing" >> "${PROJECT_DIR}/var/log/gate.log" 2>/dev/null || true
        fi
    fi
fi

# Load capability manifest (v0 — the interface to governance)
# See docs/MANIFEST-INVARIANTS.md for design invariants.
# Missing manifest = backward compatible (policy-only). Tampered = hard deny.
# FIX: Presence tracking — if a manifest was ever successfully loaded, absence
# is treated as a tamper event, not a benign missing-manifest fallback.
MANIFEST_LOADED="false"
MANIFEST_JSON=""
MANIFEST_HARD_DENY_REASON=""  # Set during load, checked in main() where respond_deny is available
MANIFEST_FILE="${PROJECT_DIR}/etc/manifest.json"
MANIFEST_SEQ_FILE="${PROJECT_DIR}/var/log/.manifest-last-seq"

# FIX: Presence detection via seq file — if seq file exists, a manifest was
# previously loaded. A missing manifest after that = deletion attack, not a
# benign first-deployment scenario. One file serves both purposes (presence +
# replay protection). No separate .manifest-present file needed.
if [ ! -f "${MANIFEST_FILE}" ] && [ -f "${MANIFEST_SEQ_FILE}" ]; then
    echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [gate] CRITICAL: Manifest was present but is now missing — possible deletion attack. Hard deny." >> "${PROJECT_DIR}/var/log/gate.log" 2>/dev/null || true
    # Send Telegram alert best-effort
    if [ -n "${TELEGRAM_TOKEN:-}" ] && [ -n "${TELEGRAM_CHAT_ID:-}" ]; then
        _alert_body=$(jq -n --arg chat "${TELEGRAM_CHAT_ID}" \
            '{"chat_id":$chat,"text":"🚨 ZLAR CRITICAL: Manifest file was present but is now missing. Possible deletion attack. Gate is hard-denied until manifest is restored.","parse_mode":"Markdown"}')
        curl -s -m 10 -X POST "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage" \
            -H "Content-Type: application/json" -d "${_alert_body}" >/dev/null 2>&1 || true
    fi
    # Flag for hard deny — respond_deny not yet defined at this point in the script.
    # The flag is checked in main() where all functions are available.
    MANIFEST_HARD_DENY_REASON="manifest:deletion_attack|Manifest was present but is now missing — possible deletion attack. Restore manifest to resume."
fi

if [ -f "${MANIFEST_FILE}" ] && command -v jq &>/dev/null; then
    # Check signature if pubkey exists
    _manifest_sig=$(jq -r '.signature.value // ""' "${MANIFEST_FILE}" 2>/dev/null)
    _manifest_ok="true"
    if [ -n "${_manifest_sig}" ] && [ -f "${POLICY_PUBKEY}" ]; then
        # Phase B of ADR-011 — dual canonical form verification.
        _m_canon_spec=$(mktemp "${GATE_TMP}/m-canon-spec.XXXXXX")
        _m_canon_pipe=$(mktemp "${GATE_TMP}/m-canon-pipe.XXXXXX")
        _m_hash_spec=$(mktemp "${GATE_TMP}/m-hash-spec.XXXXXX")
        _m_hash_pipe=$(mktemp "${GATE_TMP}/m-hash-pipe.XXXXXX")
        _m_sig_bin=$(mktemp "${GATE_TMP}/m-sig.XXXXXX")

        jq -S -c '.signature = {algorithm:"",value:"",key_id:""}' "${MANIFEST_FILE}" | tr -d '\n' > "${_m_canon_spec}" 2>/dev/null
        zlar_crypto_hash "${_m_canon_spec}" "${_m_hash_spec}"

        jq -S -c '.signature = {algorithm:"",value:"",key_id:""}' "${MANIFEST_FILE}" > "${_m_canon_pipe}" 2>/dev/null
        zlar_crypto_hash "${_m_canon_pipe}" "${_m_hash_pipe}"

        echo "${_manifest_sig}" | base64 -d > "${_m_sig_bin}" 2>/dev/null

        _m_verified=""
        if zlar_crypto_verify "${POLICY_PUBKEY}" "${_m_hash_spec}" "${_m_sig_bin}" "ed25519"; then
            _m_verified="spec"
        elif zlar_crypto_verify "${POLICY_PUBKEY}" "${_m_hash_pipe}" "${_m_sig_bin}" "ed25519"; then
            _m_verified="bash-pipeline"
            echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [gate] WARN: Manifest verified under LEGACY canonical form bash-pipeline (ADR-011)" >> "${PROJECT_DIR}/var/log/gate.log" 2>/dev/null || true
        fi

        rm -f "${_m_canon_spec}" "${_m_canon_pipe}" "${_m_hash_spec}" "${_m_hash_pipe}" "${_m_sig_bin}"

        if [ -z "${_m_verified}" ]; then
            _manifest_ok="false"
            echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [gate] CRITICAL: Manifest signature INVALID — manifest rejected" >> "${PROJECT_DIR}/var/log/gate.log" 2>/dev/null || true
            MANIFEST_HARD_DENY_REASON="manifest:tampered|Manifest signature INVALID — hard deny per invariant 8"
        fi
    elif [ -z "${_manifest_sig}" ]; then
        # Unsigned manifest — fall back to policy-only (invariant #7)
        _manifest_ok="false"
        echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [gate] WARNING: Manifest is unsigned — ignoring" >> "${PROJECT_DIR}/var/log/gate.log" 2>/dev/null || true
    else
        # Signature present but public key file missing — cannot verify.
        # This is misconfiguration or a key deletion attack. Fail closed.
        _manifest_ok="false"
        echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [gate] CRITICAL: Manifest is signed but public key missing — cannot verify" >> "${PROJECT_DIR}/var/log/gate.log" 2>/dev/null || true
        MANIFEST_HARD_DENY_REASON="manifest:missing_pubkey|Manifest is signed but public key file is missing — cannot verify. Possible key deletion attack."
    fi
    if [ "${_manifest_ok}" = "true" ]; then
        # Check expiry (invariant #6: expired = hard deny)
        _m_expires=$(jq -r '.expires // ""' "${MANIFEST_FILE}" 2>/dev/null)
        _m_now=$(date -u +%Y-%m-%dT%H:%M:%SZ)
        if [ -n "${_m_expires}" ] && [[ "${_m_now}" > "${_m_expires}" ]]; then
            echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [gate] CRITICAL: Manifest expired (${_m_expires}) — hard deny per invariant 6" >> "${PROJECT_DIR}/var/log/gate.log" 2>/dev/null || true
            MANIFEST_HARD_DENY_REASON="manifest:expired|Manifest expired (${_m_expires}) — hard deny per invariant 6. Renew manifest to resume."
        else
            MANIFEST_JSON=$(jq -c '.' "${MANIFEST_FILE}" 2>/dev/null)

            # FIX: Replay protection — check sequence number is strictly increasing
            # FIX: Poison detection — seq file value >> manifest.sequence = DoS attack
            _m_seq=$(echo "${MANIFEST_JSON}" | jq -r '.sequence // 0' 2>/dev/null)
            _m_last_seq=0
            [ -f "${MANIFEST_SEQ_FILE}" ] && _m_last_seq=$(cat "${MANIFEST_SEQ_FILE}" 2>/dev/null | tr -cd '0-9' || echo 0)

            # Poison check: seq file is implausibly ahead of this signed manifest.
            # The seq file only advances when a valid manifest loads — if it's more
            # than 100 ahead of a validly-signed manifest, it was externally modified.
            # Trust the signed manifest; reset the seq file and proceed.
            _POISON_THRESHOLD=100
            _m_seq_gap=$(( _m_last_seq - _m_seq ))
            if [ "${_m_seq}" != "0" ] && [ "${_m_seq_gap}" -gt "${_POISON_THRESHOLD}" ]; then
                echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [gate] CRITICAL: Seq file value ${_m_last_seq} is ${_m_seq_gap} ahead of signed manifest seq ${_m_seq} — possible seq file poisoning. Resetting to manifest sequence." >> "${PROJECT_DIR}/var/log/gate.log" 2>/dev/null || true
                if [ -n "${TELEGRAM_TOKEN:-}" ] && [ -n "${TELEGRAM_CHAT_ID:-}" ]; then
                    _alert_body=$(jq -n --arg chat "${TELEGRAM_CHAT_ID}" --arg gap "${_m_seq_gap}" \
                        '{"chat_id":$chat,"text":"🚨 ZLAR CRITICAL: Sequence file may have been poisoned (gap: \($gap)). Reset to manifest sequence. Check for unauthorized filesystem writes.","parse_mode":"Markdown"}')
                    curl -s -m 10 -X POST "https://api.telegram.org/bot${TELEGRAM_TOKEN}/sendMessage" \
                        -H "Content-Type: application/json" -d "${_alert_body}" >/dev/null 2>&1 || true
                fi
                _m_last_seq=0  # Reset — trust the signed manifest
            fi

            if [ -n "${_m_seq}" ] && [ "${_m_seq}" != "0" ] && [ "${_m_seq}" -lt "${_m_last_seq}" ]; then
                # Strictly less-than: detects manifest rollback (old manifest
                # replayed after a newer one was loaded). Equal is normal —
                # the same manifest loads on every gate invocation within a
                # session. Without this distinction, the first Telegram
                # approve-then-retry cycle hard-denies because the retry
                # presents the same seq the original call already persisted.
                echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [gate] CRITICAL: Manifest sequence ${_m_seq} < last seen ${_m_last_seq} — possible rollback attack. Hard deny." >> "${PROJECT_DIR}/var/log/gate.log" 2>/dev/null || true
                MANIFEST_LOADED="false"
                MANIFEST_JSON=""
                MANIFEST_HARD_DENY_REASON="manifest:replay|Manifest sequence ${_m_seq} < last seen ${_m_last_seq} — hard deny per invariant 10 (rollback detected)"
            else
                MANIFEST_LOADED="true"
                # Persist sequence (seq file existence also serves as presence marker)
                echo "${_m_seq}" > "${MANIFEST_SEQ_FILE}" 2>/dev/null || true
                echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) [gate] Manifest loaded: $(jq -r '.identity.agent_id // "?"' "${MANIFEST_FILE}" 2>/dev/null) (seq=${_m_seq})" >> "${PROJECT_DIR}/var/log/gate.log" 2>/dev/null || true
            fi
        fi
    fi
fi

# Env var overrides
TELEGRAM_TOKEN="${ZLAR_TELEGRAM_TOKEN:-${TELEGRAM_BOT_TOKEN:-}}"
TELEGRAM_CHAT_ID="${TELEGRAM_CHAT_ID:-7662799203}"
TELEGRAM_TIMEOUT_S="${TELEGRAM_TIMEOUT_S:-300}"
# R012 retry dedup: how long an approval is cached per (rule, session, command
# fingerprint) after the human confirms. Retries within this window replay the
# prior approval without re-asking. Bounded so stale approvals expire even if
# the command keeps retrying. Default 300s matches TELEGRAM_TIMEOUT_S.
ZLAR_APPROVED_TTL_S="${ZLAR_APPROVED_TTL_S:-300}"

