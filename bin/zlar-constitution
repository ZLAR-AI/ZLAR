#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
# ZLAR Constitution CLI — Second Authority Law
#
# Manages the constitutional layer: generate keys, sign, verify, deploy,
# inspect, validate policy against constitution.
#
# The constitution constrains what operational policies are permitted to
# contain. It is signed with a separate key from the policy signing key.
# Key separation is structural, not advisory.
#
# Usage:
#   zlar-constitution keygen                        Generate constitutional keypair
#   zlar-constitution sign   --input F --key K      Sign a constitution file
#   zlar-constitution verify --input F              Verify constitution signature
#   zlar-constitution deploy --input F              Deploy signed constitution
#   zlar-constitution inspect [--input F]           Display constitution summary
#   zlar-constitution validate --policy F           Check policy against constitution
#
# Phase 2 (amendment ceremony):
#   zlar-constitution propose-amendment --key K --path P --value V --reason R
#   zlar-constitution ratify --proposal ID --key K
#   zlar-constitution activate --proposal ID
#   zlar-constitution amendment-status
# ═══════════════════════════════════════════════════════════════════════════════

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
_INSTALL_DIR="$(dirname "${SCRIPT_DIR}")"
PROJECT_DIR="${ZLAR_PROJECT_DIR:-${_INSTALL_DIR}}"

# Source cryptographic abstraction layer (always from install dir, not overridden PROJECT_DIR)
export _CRYPTO_PROJECT_DIR="${_INSTALL_DIR}"
# shellcheck source=../lib/crypto.sh
source "${_INSTALL_DIR}/lib/crypto.sh"

ZLAR_ROOT="${PROJECT_DIR}/etc"
KEYS_DIR="${ZLAR_ROOT}/keys"
CONSTITUTION_FILE="${ZLAR_ROOT}/constitution.json"
CONSTITUTION_TEMPLATE="${ZLAR_ROOT}/constitution.json.template"
CONST_PUBKEY="${KEYS_DIR}/constitution-signing.pub"
POLICY_PUBKEY="${KEYS_DIR}/policy-signing.pub"
ACTIVE_POLICY="${ZLAR_ROOT}/policies/active.policy.json"
LOG_DIR="${PROJECT_DIR}/var/log"
AMENDMENTS_DIR="${PROJECT_DIR}/var/amendments"

# Colors
if [ -t 1 ]; then
    RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[0;33m'
    BLUE='\033[0;34m'; BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'
else
    RED=''; GREEN=''; YELLOW=''; BLUE=''; BOLD=''; DIM=''; NC=''
fi

ok()   { echo -e "${GREEN}  ✓${NC} $*"; }
fail() { echo -e "${RED}  ✗${NC} $*" >&2; exit 1; }
warn() { echo -e "${YELLOW}  ⚠${NC} $*"; }
info() { echo -e "${BLUE}  ℹ${NC} $*"; }

# ─── Key Generation ──────────────────────────────────────────────────────────

cmd_keygen() {
    local algo_label
    algo_label=$(zlar_crypto_label)
    echo -e "${BOLD}Generating ${algo_label} constitutional keypair${NC}"
    echo ""

    local privkey="${HOME}/.zlar-constitution.key"
    local pubkey="${CONST_PUBKEY}"

    if [ -f "${privkey}" ]; then
        warn "Constitutional private key already exists at ${privkey}"
        echo -n "  Overwrite? [y/N] "
        read -r answer
        if [ "${answer}" != "y" ] && [ "${answer}" != "Y" ]; then
            echo "  Aborted."
            return 1
        fi
    fi

    mkdir -p "${KEYS_DIR}" 2>/dev/null || true

    if ! zlar_crypto_keygen "${privkey}" "${pubkey}"; then
        fail "Key generation failed"
    fi
    ok "Private key: ${privkey} (mode 600)"
    ok "Public key:  ${pubkey} (mode 644)"

    echo ""
    info "Algorithm: ${algo_label}"
    info "This is the CONSTITUTIONAL key. It signs the constitution."
    info "It must be a DIFFERENT keypair from the policy signing key."
    info "It should NEVER be accessible to an AI agent."

    # Key separation check
    if [ -f "${POLICY_PUBKEY}" ]; then
        local const_fp policy_fp
        const_fp=$(zlar_crypto_pubkey_fingerprint "${pubkey}")
        policy_fp=$(zlar_crypto_pubkey_fingerprint "${POLICY_PUBKEY}")
        if [ "${const_fp}" = "${policy_fp}" ]; then
            fail "FATAL: Constitutional key fingerprint matches policy key. PC-06 violated. Generate a different keypair."
        fi
        ok "Key separation verified (constitutional != policy)"
    else
        warn "Policy public key not found — cannot verify key separation yet"
    fi

    echo ""
    local fingerprint
    fingerprint=$(zlar_crypto_pubkey_fingerprint "${pubkey}")
    info "Public key fingerprint (SHA-256): ${fingerprint}..."
}

# ─── Sign ────────────────────────────────────────────────────────────────────

cmd_sign() {
    local input="" key="" output="" use_yubikey="false"

    while [ $# -gt 0 ]; do
        case "$1" in
            --input)    shift; input="$1"; shift ;;
            --key)      shift; key="$1"; shift ;;
            --output)   shift; output="$1"; shift ;;
            --yubikey)  use_yubikey="true"; shift ;;
            *) shift ;;
        esac
    done

    if [ -z "${input}" ]; then
        fail "Missing --input <constitution.json>"
    fi
    if [ "${use_yubikey}" = "true" ]; then
        info "Signing with YubiKey (PIV slot 9d — constitution)"
    elif [ -z "${key}" ]; then
        key="${HOME}/.zlar-constitution.key"
        if [ ! -f "${key}" ]; then
            fail "No --key specified and default key not found at ${key}"
        fi
        info "Using default constitutional key: ${key}"
    fi
    if [ -z "${output}" ]; then
        output="${input}"
    fi

    if [ ! -f "${input}" ]; then
        fail "Constitution file not found: ${input}"
    fi
    if [ ! -f "${key}" ]; then
        fail "Constitutional private key not found: ${key}"
    fi

    echo -e "${BOLD}Signing constitution${NC}"

    # Validate JSON
    if ! jq empty "${input}" 2>/dev/null; then
        fail "Invalid JSON in ${input}"
    fi

    # Read version
    local version
    version=$(jq -r '.constitution_version // "unknown"' "${input}" 2>/dev/null)
    info "Constitution version: ${version}"

    # Count core clauses
    local clause_count
    clause_count=$(jq '.permanent_core.clauses | length' "${input}" 2>/dev/null || echo "?")
    info "Permanent core clauses: ${clause_count}"

    # Resolve algorithm
    local algo algo_label
    algo=$(zlar_crypto_algorithm)
    algo_label=$(zlar_crypto_label)
    info "Signing algorithm: ${algo_label}"

    # Extract public key for embedding
    local pubkey_b64
    if [ "${use_yubikey}" = "true" ]; then
        local _yk_pub_tmp
        _yk_pub_tmp=$(mktemp /tmp/zlar-yk-const-pub.XXXXXX)
        ykman piv keys export 9d "${_yk_pub_tmp}" --format DER 2>/dev/null || {
            rm -f "${_yk_pub_tmp}"
            fail "Failed to export public key from YubiKey slot 9d"
        }
        pubkey_b64=$(base64 < "${_yk_pub_tmp}" | tr -d '\n')
        rm -f "${_yk_pub_tmp}"
    else
        pubkey_b64=$(zlar_crypto_pubkey_b64 "${key}")
    fi

    # Create canonical form (empty signature) for signing.
    # Phase B of ADR-011 — spec form: compact, sorted, no trailing newline.
    # jq -S -c sorts and emits compact; tr -d '\n' strips the trailing
    # newline. Result matches lib/canonicalize.mjs byte-for-byte so the
    # MCP gate's spec-form verifier can validate it without LEGACY fallback.
    local canon_file
    canon_file=$(mktemp /tmp/zlar-const-canon.XXXXXX)
    jq -S -c --arg pubkey "${pubkey_b64}" \
       --arg algo "${algo}" \
       '.signature.algorithm = $algo | .signature.public_key = $pubkey | .signature.value = ""' \
       "${input}" | tr -d '\n' > "${canon_file}"

    # Hash canonical form
    local hash_file
    hash_file=$(mktemp /tmp/zlar-const-hash.XXXXXX)
    zlar_crypto_hash "${canon_file}" "${hash_file}"

    # Sign — YubiKey hardware path or disk-based key
    local sig_file
    sig_file=$(mktemp /tmp/zlar-const-sig.XXXXXX)
    if [ "${use_yubikey}" = "true" ]; then
        if ! zlar_crypto_sign_yubikey_constitution "${hash_file}" "${sig_file}"; then
            rm -f "${canon_file}" "${hash_file}" "${sig_file}"
            fail "YubiKey signing failed (check PIN and touch)"
        fi
    else
        if ! zlar_crypto_sign "${key}" "${hash_file}" "${sig_file}"; then
            rm -f "${canon_file}" "${hash_file}" "${sig_file}"
            fail "Signing failed"
        fi
    fi

    local sig_b64
    sig_b64=$(base64 < "${sig_file}" | tr -d '\n')

    # Create signed output
    local signed_tmp
    signed_tmp=$(mktemp /tmp/zlar-const-signed.XXXXXX)
    jq --arg pubkey "${pubkey_b64}" \
       --arg sig "${sig_b64}" \
       --arg algo "${algo}" \
       '.signature.algorithm = $algo | .signature.public_key = $pubkey | .signature.value = $sig' \
       "${input}" > "${signed_tmp}"
    mv "${signed_tmp}" "${output}"

    rm -f "${canon_file}" "${hash_file}" "${sig_file}"

    ok "Signed constitution written to: ${output}"

    local output_hash
    output_hash=$(shasum -a 256 "${output}" | awk '{print $1}')
    info "SHA-256: ${output_hash:0:16}..."
    echo ""
    info "To deploy: zlar-constitution deploy --input ${output}"
}

# ─── Verify ──────────────────────────────────────────────────────────────────

cmd_verify() {
    local input="" pubkey=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --input)  shift; input="$1"; shift ;;
            --pubkey) shift; pubkey="$1"; shift ;;
            *) shift ;;
        esac
    done

    if [ -z "${input}" ]; then
        input="${CONSTITUTION_FILE}"
    fi
    if [ -z "${pubkey}" ]; then
        pubkey="${CONST_PUBKEY}"
    fi

    if [ ! -f "${input}" ]; then
        fail "Constitution file not found: ${input}"
    fi
    if [ ! -f "${pubkey}" ]; then
        fail "Constitutional public key not found: ${pubkey}"
    fi

    echo -e "${BOLD}Verifying constitution signature${NC}"

    local sig_value sig_algo
    sig_value=$(jq -r '.signature.value // ""' "${input}" 2>/dev/null)
    sig_algo=$(jq -r '.signature.algorithm // "ed25519"' "${input}" 2>/dev/null)

    if [ -z "${sig_value}" ] || [ "${sig_value}" = "" ]; then
        fail "Constitution has no signature"
    fi

    info "Signature algorithm: ${sig_algo}"

    # Phase B of ADR-011 — accept spec form (new) AND bash-pretty legacy
    # form (existing deployed artifacts). Order matters: try spec first so
    # new signatures do not trip the LEGACY warning.
    local canon_spec canon_pretty hash_spec hash_pretty sig_file
    canon_spec=$(mktemp /tmp/zlar-const-verify-canon-spec.XXXXXX)
    canon_pretty=$(mktemp /tmp/zlar-const-verify-canon-pretty.XXXXXX)
    hash_spec=$(mktemp /tmp/zlar-const-verify-hash-spec.XXXXXX)
    hash_pretty=$(mktemp /tmp/zlar-const-verify-hash-pretty.XXXXXX)
    sig_file=$(mktemp /tmp/zlar-const-verify-sig.XXXXXX)

    jq -S -c '.signature.value = ""' "${input}" | tr -d '\n' > "${canon_spec}"
    zlar_crypto_hash "${canon_spec}" "${hash_spec}"

    jq '.signature.value = ""' "${input}" > "${canon_pretty}"
    zlar_crypto_hash "${canon_pretty}" "${hash_pretty}"

    echo "${sig_value}" | base64 -d > "${sig_file}" 2>/dev/null

    local _const_verified=""
    if zlar_crypto_verify "${pubkey}" "${hash_spec}" "${sig_file}" "${sig_algo}"; then
        _const_verified="spec"
    elif zlar_crypto_verify "${pubkey}" "${hash_pretty}" "${sig_file}" "${sig_algo}"; then
        _const_verified="bash-pretty"
    fi

    rm -f "${canon_spec}" "${canon_pretty}" "${hash_spec}" "${hash_pretty}" "${sig_file}"

    if [ "${_const_verified}" = "spec" ]; then
        ok "Constitution signature is VALID (spec canonical form)"
    elif [ "${_const_verified}" = "bash-pretty" ]; then
        ok "Constitution signature is VALID"
        warn "Verified under LEGACY canonical form \"bash-pretty\" — migration tracked by ADR-011."
    else
        fail "Constitution signature is INVALID (tried spec and bash-pretty canonical forms)"
    fi

    local version author
    version=$(jq -r '.constitution_version // "unknown"' "${input}" 2>/dev/null)
    author=$(jq -r '.author // "unknown"' "${input}" 2>/dev/null)
    info "Version: ${version}"
    info "Author:  ${author}"
}

# ─── Deploy ──────────────────────────────────────────────────────────────────

cmd_deploy() {
    local input=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --input) shift; input="$1"; shift ;;
            *) shift ;;
        esac
    done

    if [ -z "${input}" ]; then
        fail "Missing --input <signed-constitution.json>"
    fi
    if [ ! -f "${input}" ]; then
        fail "Constitution file not found: ${input}"
    fi

    echo -e "${BOLD}Deploying constitution${NC}"

    # Verify signature before deploy
    if [ -f "${CONST_PUBKEY}" ]; then
        info "Verifying signature before deploy..."
        if ! cmd_verify --input "${input}" --pubkey "${CONST_PUBKEY}" >/dev/null 2>&1; then
            fail "Constitution signature verification FAILED — cannot deploy"
        fi
        ok "Signature verified"
    else
        fail "Constitutional public key not found — cannot verify"
    fi

    # Key separation check (PC-06)
    if [ -f "${POLICY_PUBKEY}" ] && [ -f "${CONST_PUBKEY}" ]; then
        local const_fp policy_fp
        const_fp=$(zlar_crypto_pubkey_fingerprint "${CONST_PUBKEY}")
        policy_fp=$(zlar_crypto_pubkey_fingerprint "${POLICY_PUBKEY}")
        if [ "${const_fp}" = "${policy_fp}" ]; then
            fail "PC-06 VIOLATED: Constitutional key fingerprint matches policy key. Deploy rejected."
        fi
        ok "Key separation verified (PC-06)"
    fi

    # Archive current constitution if exists
    if [ -f "${CONSTITUTION_FILE}" ]; then
        local current_version
        current_version=$(jq -r '.constitution_version // "unknown"' "${CONSTITUTION_FILE}" 2>/dev/null)
        local archive_dir="${ZLAR_ROOT}/constitutions/archive"
        mkdir -p "${archive_dir}" 2>/dev/null || true
        local archive_name="constitution-v${current_version}-$(date +%Y%m%d%H%M%S).json"
        cp "${CONSTITUTION_FILE}" "${archive_dir}/${archive_name}"
        info "Archived current constitution: ${archive_name}"
    fi

    # Atomic deploy
    local deploy_tmp="${CONSTITUTION_FILE}.deploying"
    cp "${input}" "${deploy_tmp}"
    mv "${deploy_tmp}" "${CONSTITUTION_FILE}"

    # Write presence tracker (same pattern as manifest seq file)
    local presence_file="${LOG_DIR}/.constitution-last-hash"
    mkdir -p "${LOG_DIR}" 2>/dev/null || true
    shasum -a 256 "${CONSTITUTION_FILE}" | awk '{print $1}' > "${presence_file}"

    ok "Constitution deployed to: ${CONSTITUTION_FILE}"

    local version
    version=$(jq -r '.constitution_version // "unknown"' "${CONSTITUTION_FILE}" 2>/dev/null)
    info "Active constitution: v${version}"
    echo ""
    info "The gate will now validate policy against this constitution."
    info "Pre-constitutional mode is permanently disabled for this installation."
}

# ─── Inspect ─────────────────────────────────────────────────────────────────

cmd_inspect() {
    local input=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --input) shift; input="$1"; shift ;;
            *) shift ;;
        esac
    done

    if [ -z "${input}" ]; then
        input="${CONSTITUTION_FILE}"
    fi

    if [ ! -f "${input}" ]; then
        fail "Constitution file not found: ${input}"
    fi

    local version author created
    version=$(jq -r '.constitution_version // "unknown"' "${input}" 2>/dev/null)
    author=$(jq -r '.author // "unknown"' "${input}" 2>/dev/null)
    created=$(jq -r '.created_at // "unknown"' "${input}" 2>/dev/null)

    echo -e "${BOLD}ZLAR Constitution v${version}${NC}"
    echo ""

    # Preamble
    local preamble
    preamble=$(jq -r '.preamble // ""' "${input}" 2>/dev/null)
    if [ -n "${preamble}" ]; then
        echo -e "  ${DIM}${preamble}${NC}"
        echo ""
    fi

    # Signature status
    local sig_value
    sig_value=$(jq -r '.signature.value // ""' "${input}" 2>/dev/null)
    if [ -n "${sig_value}" ] && [ "${sig_value}" != "" ]; then
        ok "Signed"
    else
        warn "UNSIGNED"
    fi
    info "Author: ${author}"
    info "Created: ${created}"
    echo ""

    # Permanent core
    echo -e "${BOLD}Permanent Core (unamendable)${NC}"
    local clause_count
    clause_count=$(jq '.permanent_core.clauses | length' "${input}" 2>/dev/null)
    local i=0
    while [ "${i}" -lt "${clause_count}" ]; do
        local cid ctitle
        cid=$(jq -r ".permanent_core.clauses[${i}].id" "${input}" 2>/dev/null)
        ctitle=$(jq -r ".permanent_core.clauses[${i}].title" "${input}" 2>/dev/null)
        echo -e "  ${GREEN}${cid}${NC}  ${ctitle}"
        i=$((i + 1))
    done
    echo ""

    # Derived properties
    echo -e "${BOLD}Derived Properties${NC}"
    local dp_count
    dp_count=$(jq '.derived_properties.properties | length' "${input}" 2>/dev/null)
    i=0
    while [ "${i}" -lt "${dp_count}" ]; do
        local did dtitle
        did=$(jq -r ".derived_properties.properties[${i}].id" "${input}" 2>/dev/null)
        dtitle=$(jq -r ".derived_properties.properties[${i}].title" "${input}" 2>/dev/null)
        echo -e "  ${BLUE}${did}${NC}  ${dtitle}"
        i=$((i + 1))
    done
    echo ""

    # Observability
    echo -e "${BOLD}Observability Obligations${NC}"
    local ob_count
    ob_count=$(jq '.observability_obligations.obligations | length' "${input}" 2>/dev/null)
    i=0
    while [ "${i}" -lt "${ob_count}" ]; do
        local oid otitle
        oid=$(jq -r ".observability_obligations.obligations[${i}].id" "${input}" 2>/dev/null)
        otitle=$(jq -r ".observability_obligations.obligations[${i}].title" "${input}" 2>/dev/null)
        echo -e "  ${YELLOW}${oid}${NC}  ${otitle}"
        i=$((i + 1))
    done
    echo ""

    # Amendable constraints summary
    echo -e "${BOLD}Amendable Constraints${NC}"
    local retention cooling_off
    retention=$(jq -r '.amendable_constraints.evidence.minimum_retention_hours // "?"' "${input}" 2>/dev/null)
    cooling_off=$(jq -r '.amendable_constraints.amendment_ceremony.cooling_off_period_hours // "?"' "${input}" 2>/dev/null)
    info "Evidence retention: ${retention} hours"
    info "Amendment cooling-off: ${cooling_off} hours"
    local esc_suspended
    esc_suspended=$(jq -r '.amendable_constraints.escalation.suspended // "?"' "${input}" 2>/dev/null)
    info "Suspended escalation: ${esc_suspended}"

    # Manifest required deny classes
    echo ""
    echo -e "${BOLD}Manifest Required Deny Classes (PC-05)${NC}"
    jq -r '.amendable_constraints.manifest_deny_required_classes[]' "${input}" 2>/dev/null | while read -r cls; do
        echo -e "  ${RED}deny${NC}  ${cls}"
    done

    # Surface pending amendments (Tomas's requirement)
    if [ -d "${AMENDMENTS_DIR}" ]; then
        local pending_count=0
        for _af in "${AMENDMENTS_DIR}"/*.proposal.json; do
            [ -f "${_af}" ] || continue
            local _as
            _as=$(jq -r '.state' "${_af}" 2>/dev/null)
            if [ "${_as}" = "proposed" ] || [ "${_as}" = "ratified" ]; then
                pending_count=$((pending_count + 1))
            fi
        done
        if [ "${pending_count}" -gt 0 ]; then
            echo ""
            echo -e "${YELLOW}${BOLD}⚠ ${pending_count} pending amendment(s)${NC}"
            echo -e "  Run: zlar-constitution amendment-status"
        fi
    fi
}

# ─── Validate ────────────────────────────────────────────────────────────────
# Check an operational policy against the constitution.
# This is the offline version of what the gate does at load time.

cmd_validate() {
    local policy="" constitution=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --policy)       shift; policy="$1"; shift ;;
            --constitution) shift; constitution="$1"; shift ;;
            *) shift ;;
        esac
    done

    if [ -z "${policy}" ]; then
        policy="${ACTIVE_POLICY}"
    fi
    if [ -z "${constitution}" ]; then
        constitution="${CONSTITUTION_FILE}"
    fi

    if [ ! -f "${policy}" ]; then
        fail "Policy file not found: ${policy}"
    fi
    if [ ! -f "${constitution}" ]; then
        fail "Constitution file not found: ${constitution}"
    fi

    echo -e "${BOLD}Validating policy against constitution${NC}"
    echo ""

    local violations=0

    # PC-01: No rule exercising consequential power with audit: false
    local silent_rules
    silent_rules=$(jq -r '
      [.rules[] |
        select(
          (.audit == false) and
          ((.risk_score.irreversibility // 0) > 0 or
           (.risk_score.consequence // 0) > 0 or
           (.risk_score.blast_radius // 0) > 0)
        ) | .id
      ] | join(", ")' "${policy}" 2>/dev/null)
    if [ -n "${silent_rules}" ]; then
        echo -e "  ${RED}✗ PC-01${NC}  Silent consequential power: rules ${silent_rules} have audit:false with risk > 0"
        violations=$((violations + 1))
    else
        echo -e "  ${GREEN}✓ PC-01${NC}  No silent consequential power"
    fi

    # PC-02: At least one ask rule exists (human contestability path)
    local ask_count
    ask_count=$(jq '[.rules[] | select(.action == "ask")] | length' "${policy}" 2>/dev/null)
    if [ "${ask_count:-0}" -eq 0 ]; then
        echo -e "  ${RED}✗ PC-02${NC}  No ask rules — no human contestability path"
        violations=$((violations + 1))
    else
        echo -e "  ${GREEN}✓ PC-02${NC}  Human contestability: ${ask_count} ask rules"
    fi

    # PC-04: Suspended escalation must be deny
    if [ -f "${PROJECT_DIR}/etc/restore-config.json" ]; then
        local esc_suspended
        esc_suspended=$(jq -r '.escalation.suspended // "deny"' "${PROJECT_DIR}/etc/restore-config.json" 2>/dev/null)
        if [ "${esc_suspended}" != "deny" ]; then
            echo -e "  ${RED}✗ PC-04${NC}  Suspended escalation is '${esc_suspended}', must be 'deny'"
            violations=$((violations + 1))
        else
            echo -e "  ${GREEN}✓ PC-04${NC}  Suspended means full stop"
        fi
    else
        echo -e "  ${DIM}  PC-04${NC}  Restore config not found — skipped"
    fi

    # PC-05: default_action must be deny (deny-wins)
    local default_action
    default_action=$(jq -r '.default_action // ""' "${policy}" 2>/dev/null)
    if [ "${default_action}" != "deny" ]; then
        echo -e "  ${RED}✗ PC-05${NC}  default_action is '${default_action}', must be 'deny'"
        violations=$((violations + 1))
    else
        echo -e "  ${GREEN}✓ PC-05${NC}  Deny-wins: default_action is deny"
    fi

    # PC-05: Manifest deny-required classes
    if [ -f "${ZLAR_ROOT}/manifest.json" ]; then
        local required_classes manifest_denies missing_denies
        required_classes=$(jq -r '.amendable_constraints.manifest_deny_required_classes[]' "${constitution}" 2>/dev/null)
        manifest_denies=$(jq -r '.authority.deny[]' "${ZLAR_ROOT}/manifest.json" 2>/dev/null)
        missing_denies=""
        for rc in ${required_classes}; do
            if ! echo "${manifest_denies}" | grep -q "^${rc}$" 2>/dev/null; then
                missing_denies="${missing_denies} ${rc}"
            fi
        done
        if [ -n "${missing_denies}" ]; then
            echo -e "  ${RED}✗ PC-05${NC}  Manifest missing required deny classes:${missing_denies}"
            violations=$((violations + 1))
        else
            echo -e "  ${GREEN}✓ PC-05${NC}  Manifest denies all governance-critical powers"
        fi
    else
        echo -e "  ${DIM}  PC-05${NC}  Manifest not found — skipped"
    fi

    # PC-06: Key separation
    if [ -f "${CONST_PUBKEY}" ] && [ -f "${POLICY_PUBKEY}" ]; then
        local const_fp policy_fp
        const_fp=$(zlar_crypto_pubkey_fingerprint "${CONST_PUBKEY}")
        policy_fp=$(zlar_crypto_pubkey_fingerprint "${POLICY_PUBKEY}")
        if [ "${const_fp}" = "${policy_fp}" ]; then
            echo -e "  ${RED}✗ PC-06${NC}  Constitutional key = policy key (fingerprints match)"
            violations=$((violations + 1))
        else
            echo -e "  ${GREEN}✓ PC-06${NC}  Key separation verified"
        fi
    else
        echo -e "  ${DIM}  PC-06${NC}  Keys not found — skipped"
    fi

    echo ""
    if [ "${violations}" -gt 0 ]; then
        fail "CONSTITUTIONAL VALIDATION FAILED: ${violations} violation(s)"
    else
        ok "Policy passes all constitutional checks"
    fi
}

# ─── Telegram Notification (OB-03) ──────────────────────────────────────────
# Best-effort push to human channel. Failure is logged, never blocks ceremony.

_notify_telegram() {
    local event="$1" detail="$2"

    # Load Telegram credentials
    local token="" chat_id=""
    local env_file="${PROJECT_DIR}/.env"
    if [ -f "${env_file}" ]; then
        while IFS='=' read -r key value; do
            [[ "${key}" =~ ^[[:space:]]*# ]] && continue
            [[ -z "${key}" ]] && continue
            value="${value%\"}"; value="${value#\"}"
            value="${value%\'}"; value="${value#\'}"
            case "${key}" in
                TELEGRAM_BOT_TOKEN|ZLAR_TELEGRAM_TOKEN) token="${value}" ;;
            esac
        done < "${env_file}"
    fi
    token="${ZLAR_TELEGRAM_TOKEN:-${TELEGRAM_BOT_TOKEN:-${token}}}"

    # Chat ID from gate config
    if [ -f "${PROJECT_DIR}/etc/gate.json" ]; then
        chat_id=$(jq -r '.telegram.chat_id // ""' "${PROJECT_DIR}/etc/gate.json" 2>/dev/null)
    fi
    chat_id="${ZLAR_TELEGRAM_CHAT_ID:-${chat_id:-}}"

    if [ -z "${token}" ] || [ -z "${chat_id}" ]; then
        warn "Telegram not configured — OB-03 notification not delivered"
        return 1
    fi

    local msg="📜 *ZLAR Constitution*

*Event:* ${event}
${detail}"

    # Escape MarkdownV2
    msg=$(echo "${msg}" | sed 's/[]_[()~>#+=|{}.!-]/\\&/g' | sed 's/\\`/`/g' | sed 's/\\\*/*/g')

    local body
    body=$(jq -n -c --arg chat "${chat_id}" --arg text "${msg}" \
        '{chat_id:$chat,text:$text,parse_mode:"MarkdownV2"}')

    curl -s --connect-timeout 5 --max-time 10 \
        -X POST -H "Content-Type: application/json" \
        -d "${body}" \
        --config - 2>/dev/null <<EOF
url = "https://api.telegram.org/bot${token}/sendMessage"
EOF
    local rc=$?
    if [ ${rc} -ne 0 ]; then
        warn "Telegram notification failed (OB-03)"
        return 1
    fi
    return 0
}

# ─── Amendment ID Generation ────────────────────────────────────────────────

_amendment_id() {
    local hex_ts
    hex_ts=$(printf '%x' "$(date +%s)")
    local rand
    rand=$(openssl rand -hex 8 2>/dev/null || head -c 16 /dev/urandom | xxd -p)
    echo "amend-${hex_ts}-${rand}"
}

# ─── DP-03: Parameter Consistency Check ─────────────────────────────────────
# Validates that a parameter set preserves all Layer 1 and Layer 2 obligations.
# All constraints are linear inequalities on individual parameters (convex
# admissible region), so single-point checking is sufficient.

_dp03_check() {
    local constitution_file="$1"
    local violations=0

    # PC-02: burden proxy floors must be >= 1 (prevent zero-factor collapse)
    local cw_floor cl_floor
    cw_floor=$(jq -r '.amendable_constraints.burden_proxy.consequence_weight_floor // 1' "${constitution_file}" 2>/dev/null)
    cl_floor=$(jq -r '.amendable_constraints.burden_proxy.context_load_weight_floor // 1' "${constitution_file}" 2>/dev/null)
    if [ "${cw_floor}" -lt 1 ] 2>/dev/null || [ "${cl_floor}" -lt 1 ] 2>/dev/null; then
        echo "DP-03: Burden proxy floors < 1 violates PC-02 (zero-factor collapse)"
        violations=$((violations + 1))
    fi

    # PC-02: deliberation floors must be > 0
    local df_crit df_warn df_info
    df_crit=$(jq -r '.amendable_constraints.human_judgment.deliberation_floor_critical_seconds // 30' "${constitution_file}" 2>/dev/null)
    df_warn=$(jq -r '.amendable_constraints.human_judgment.deliberation_floor_warn_seconds // 10' "${constitution_file}" 2>/dev/null)
    df_info=$(jq -r '.amendable_constraints.human_judgment.deliberation_floor_info_seconds // 3' "${constitution_file}" 2>/dev/null)
    if [ "${df_crit}" -le 0 ] 2>/dev/null || [ "${df_warn}" -le 0 ] 2>/dev/null || [ "${df_info}" -le 0 ] 2>/dev/null; then
        echo "DP-03: Deliberation floor <= 0 violates PC-02 (human review cannot be instantaneous)"
        violations=$((violations + 1))
    fi

    # PC-02: deliberation ordering (critical >= warn >= info)
    if [ "${df_crit}" -lt "${df_warn}" ] 2>/dev/null; then
        echo "DP-03: critical deliberation floor < warn floor violates PC-02 ordering"
        violations=$((violations + 1))
    fi
    if [ "${df_warn}" -lt "${df_info}" ] 2>/dev/null; then
        echo "DP-03: warn deliberation floor < info floor violates PC-02 ordering"
        violations=$((violations + 1))
    fi

    # PC-02: daily decision cap must be >= min and <= max
    local min_cap max_cap
    min_cap=$(jq -r '.amendable_constraints.human_judgment.min_daily_decision_cap // 20' "${constitution_file}" 2>/dev/null)
    max_cap=$(jq -r '.amendable_constraints.human_judgment.max_daily_decision_cap // 200' "${constitution_file}" 2>/dev/null)
    if [ "${min_cap}" -le 0 ] 2>/dev/null; then
        echo "DP-03: min_daily_decision_cap <= 0 violates PC-02"
        violations=$((violations + 1))
    fi
    if [ "${max_cap}" -lt "${min_cap}" ] 2>/dev/null; then
        echo "DP-03: max_daily_decision_cap < min violates PC-02"
        violations=$((violations + 1))
    fi

    # PC-04: suspended escalation must be deny
    local esc_suspended
    esc_suspended=$(jq -r '.amendable_constraints.escalation.suspended // "deny"' "${constitution_file}" 2>/dev/null)
    if [ "${esc_suspended}" != "deny" ]; then
        echo "DP-03: suspended escalation is '${esc_suspended}', must be 'deny' (PC-04)"
        violations=$((violations + 1))
    fi

    # DP-02: cooling-off must be >= minimum floor (24h)
    local cooling_off min_cooling
    cooling_off=$(jq -r '.amendable_constraints.amendment_ceremony.cooling_off_period_hours // 72' "${constitution_file}" 2>/dev/null)
    min_cooling=$(jq -r '.amendable_constraints.amendment_ceremony.minimum_cooling_off_hours // 24' "${constitution_file}" 2>/dev/null)
    if [ "${cooling_off}" -lt "${min_cooling}" ] 2>/dev/null; then
        echo "DP-03: cooling_off_period (${cooling_off}h) < minimum (${min_cooling}h) violates DP-02"
        violations=$((violations + 1))
    fi
    if [ "${min_cooling}" -le 0 ] 2>/dev/null; then
        echo "DP-03: minimum_cooling_off_hours <= 0 violates DP-02 (nonzero delay required)"
        violations=$((violations + 1))
    fi

    # OB-02: evidence retention must be > 0
    local retention
    retention=$(jq -r '.amendable_constraints.evidence.minimum_retention_hours // 720' "${constitution_file}" 2>/dev/null)
    if [ "${retention}" -le 0 ] 2>/dev/null; then
        echo "DP-03: evidence retention <= 0 violates OB-02"
        violations=$((violations + 1))
    fi

    # PC-05: all six governance-critical powers must be in required deny list
    # Check content, not just cardinality — ["a","b","c","d","e","f"] must not pass
    local _required_class _deny_classes
    _deny_classes=$(jq -r '.amendable_constraints.manifest_deny_required_classes[]' "${constitution_file}" 2>/dev/null)
    for _required_class in governance_mutation evidence_mutation stop_restart_control \
        key_material_signing_authority self_expansion_of_authority communication_channel_mutation; do
        if ! echo "${_deny_classes}" | grep -q "^${_required_class}$" 2>/dev/null; then
            echo "DP-03: manifest_deny_required_classes missing '${_required_class}' (PC-05)"
            violations=$((violations + 1))
        fi
    done

    return ${violations}
}

# ─── Propose Amendment ──────────────────────────────────────────────────────

cmd_propose_amendment() {
    local key="" path="" value="" reason=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --key)    shift; key="$1"; shift ;;
            --path)   shift; path="$1"; shift ;;
            --value)  shift; value="$1"; shift ;;
            --reason) shift; reason="$1"; shift ;;
            *) shift ;;
        esac
    done

    if [ -z "${key}" ]; then
        fail "Missing --key <constitutional-private-key>"
    fi
    if [ -z "${path}" ]; then
        fail "Missing --path <amendable_constraints.X.Y>"
    fi
    if [ -z "${value}" ]; then
        fail "Missing --value <new-value>"
    fi
    if [ -z "${reason}" ]; then
        fail "Missing --reason <justification>"
    fi
    if [ ! -f "${key}" ]; then
        fail "Constitutional key not found: ${key}"
    fi

    echo -e "${BOLD}Proposing Constitutional Amendment${NC}"
    echo ""

    # Verify constitution exists and is deployed
    if [ ! -f "${CONSTITUTION_FILE}" ]; then
        fail "No deployed constitution. Deploy first: zlar-constitution deploy --input <file>"
    fi

    # Reject amendments targeting permanent core (PC-07: regime change, not amendment)
    case "${path}" in
        permanent_core*|derived_properties*|preamble*|scope*|incompleteness*|definitions*)
            fail "Cannot amend '${path}' — this targets the permanent core or structural elements. Changing these is regime replacement, not amendment. It must be declared as such (PC-07)."
            ;;
        amendable_constraints.*)
            ;; # Valid target
        *)
            fail "Amendment path must target 'amendable_constraints.*'. Got: '${path}'"
            ;;
    esac

    # Extract current value
    local jq_path
    jq_path=$(echo "${path}" | sed 's/\././g')  # Already dotted
    local current_value
    current_value=$(jq -r ".${jq_path} // null" "${CONSTITUTION_FILE}" 2>/dev/null)
    if [ "${current_value}" = "null" ]; then
        warn "Path '${path}' does not exist in current constitution — this will create it"
    fi

    # Read cooling-off period from constitution
    local cooling_off_hours
    cooling_off_hours=$(jq -r '.amendable_constraints.amendment_ceremony.cooling_off_period_hours // 72' "${CONSTITUTION_FILE}" 2>/dev/null)

    # Generate proposal
    local proposal_id
    proposal_id=$(_amendment_id)
    local now_iso
    now_iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    local now_epoch
    now_epoch=$(date +%s)
    local deadline_epoch=$((now_epoch + cooling_off_hours * 3600))
    local deadline_iso
    deadline_iso=$(date -u -r "${deadline_epoch}" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || date -u -d "@${deadline_epoch}" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null)

    # Get proposer key fingerprint
    local proposer_fp
    local pubkey_tmp
    pubkey_tmp=$(mktemp /tmp/zlar-amend-pub.XXXXXX)
    if zlar_crypto_extract_pubkey "${key}" "${pubkey_tmp}" 2>/dev/null; then
        proposer_fp=$(zlar_crypto_pubkey_fingerprint "${pubkey_tmp}" 2>/dev/null || echo "unknown")
    else
        proposer_fp="unknown"
    fi
    rm -f "${pubkey_tmp}"

    # Detect value type for JSON construction
    local json_value
    if echo "${value}" | jq empty 2>/dev/null; then
        json_value="${value}"  # Already valid JSON
    elif [[ "${value}" =~ ^[0-9]+$ ]]; then
        json_value="${value}"  # Integer
    elif [[ "${value}" =~ ^[0-9]+\.[0-9]+$ ]]; then
        json_value="${value}"  # Float
    elif [ "${value}" = "true" ] || [ "${value}" = "false" ]; then
        json_value="${value}"  # Boolean
    else
        json_value="\"${value}\""  # String
    fi

    # Build unsigned proposal
    local unsigned_proposal
    unsigned_proposal=$(jq -n -c \
        --arg pid "${proposal_id}" \
        --arg proposed_at "${now_iso}" \
        --arg proposer_fp "${proposer_fp}" \
        --arg target_path "${path}" \
        --argjson current_value "$(echo "${current_value}" | jq -R 'try fromjson catch .')" \
        --argjson proposed_value "${json_value}" \
        --arg reason "${reason}" \
        --arg deadline "${deadline_iso}" \
        --arg state "proposed" \
        '{
            proposal_id: $pid,
            proposed_at: $proposed_at,
            proposer_key_fingerprint: $proposer_fp,
            target_path: $target_path,
            current_value: $current_value,
            proposed_value: $proposed_value,
            reason: $reason,
            cooling_off_deadline: $deadline,
            state: $state,
            ob03_notifications: [],
            signature: {algorithm: "", value: "", key_id: ""}
        }')

    # Sign proposal (state is in the signed payload — Number Theorist requirement)
    local canon_file hash_file sig_file
    canon_file=$(mktemp /tmp/zlar-amend-canon.XXXXXX)
    hash_file=$(mktemp /tmp/zlar-amend-hash.XXXXXX)
    sig_file=$(mktemp /tmp/zlar-amend-sig.XXXXXX)

    echo "${unsigned_proposal}" | jq -S -c '.' > "${canon_file}"
    zlar_crypto_hash "${canon_file}" "${hash_file}"

    if ! zlar_crypto_sign "${key}" "${hash_file}" "${sig_file}"; then
        rm -f "${canon_file}" "${hash_file}" "${sig_file}"
        fail "Failed to sign proposal"
    fi

    local sig_b64
    sig_b64=$(base64 < "${sig_file}" | tr -d '\n')
    local algo
    algo=$(zlar_crypto_algorithm)

    rm -f "${canon_file}" "${hash_file}" "${sig_file}"

    # Assemble signed proposal
    local signed_proposal
    signed_proposal=$(echo "${unsigned_proposal}" | jq -c \
        --arg algo "${algo}" \
        --arg sig "${sig_b64}" \
        --arg key_id "${proposer_fp}" \
        '.signature.algorithm = $algo | .signature.value = $sig | .signature.key_id = $key_id')

    # Write proposal
    mkdir -p "${AMENDMENTS_DIR}" 2>/dev/null || true
    echo "${signed_proposal}" | jq '.' > "${AMENDMENTS_DIR}/${proposal_id}.proposal.json"

    ok "Amendment proposed: ${proposal_id}"
    info "Target: ${path}"
    info "Current value: ${current_value}"
    info "Proposed value: ${value}"
    info "Reason: ${reason}"
    info "Cooling-off: ${cooling_off_hours} hours"
    info "Deadline: ${deadline_iso}"
    echo ""

    # OB-03: notify human channel
    local ob03_delivered="false"
    if _notify_telegram "Amendment Proposed" "*Proposal:* \`${proposal_id}\`
*Path:* \`${path}\`
*Current:* ${current_value}
*Proposed:* ${value}
*Reason:* ${reason}
*Cooling\\-off:* ${cooling_off_hours}h
*Deadline:* ${deadline_iso}" 2>/dev/null; then
        ob03_delivered="true"
        ok "OB-03: Telegram notification delivered"
    else
        warn "OB-03: Telegram notification not delivered"
    fi

    # Record OB-03 delivery status
    jq --arg event "proposed" --arg ts "${now_iso}" --argjson delivered "${ob03_delivered}" \
        '.ob03_notifications += [{event: $event, delivered: $delivered, ts: $ts}]' \
        "${AMENDMENTS_DIR}/${proposal_id}.proposal.json" > "${AMENDMENTS_DIR}/${proposal_id}.proposal.json.tmp"
    mv "${AMENDMENTS_DIR}/${proposal_id}.proposal.json.tmp" "${AMENDMENTS_DIR}/${proposal_id}.proposal.json"

    info "Proposal written to: ${AMENDMENTS_DIR}/${proposal_id}.proposal.json"
}

# ─── Ratify Amendment ───────────────────────────────────────────────────────

cmd_ratify() {
    local proposal="" key=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --proposal) shift; proposal="$1"; shift ;;
            --key)      shift; key="$1"; shift ;;
            *) shift ;;
        esac
    done

    if [ -z "${proposal}" ]; then
        fail "Missing --proposal <proposal-id>"
    fi
    if [ -z "${key}" ]; then
        fail "Missing --key <constitutional-private-key> (explicit key required for ceremony acts)"
    fi
    if [ ! -f "${key}" ]; then
        fail "Constitutional key not found: ${key}"
    fi

    local proposal_file="${AMENDMENTS_DIR}/${proposal}.proposal.json"
    if [ ! -f "${proposal_file}" ]; then
        fail "Proposal not found: ${proposal}"
    fi

    echo -e "${BOLD}Ratifying Amendment${NC}"
    echo ""

    # Check state
    local state
    state=$(jq -r '.state' "${proposal_file}" 2>/dev/null)
    if [ "${state}" != "proposed" ]; then
        fail "Proposal is in state '${state}', must be 'proposed' to ratify"
    fi

    # Verify proposal signature
    local prop_sig prop_algo
    prop_sig=$(jq -r '.signature.value // ""' "${proposal_file}" 2>/dev/null)
    prop_algo=$(jq -r '.signature.algorithm // "ed25519"' "${proposal_file}" 2>/dev/null)
    if [ -z "${prop_sig}" ]; then
        fail "Proposal has no signature — cannot verify authenticity"
    fi

    if [ -f "${CONST_PUBKEY}" ]; then
        local _v_canon _v_hash _v_sig
        _v_canon=$(mktemp /tmp/zlar-ratify-canon.XXXXXX)
        _v_hash=$(mktemp /tmp/zlar-ratify-hash.XXXXXX)
        _v_sig=$(mktemp /tmp/zlar-ratify-sig.XXXXXX)
        # Canonical form: zero signature and ob03_notifications (ob03 is appended
        # after signing and changes between propose/ratify). The signature covers
        # the proposal content, not the delivery tracking metadata.
        jq -S -c '.signature = {algorithm:"",value:"",key_id:""} | .ob03_notifications = []' "${proposal_file}" > "${_v_canon}"
        zlar_crypto_hash "${_v_canon}" "${_v_hash}"
        echo "${prop_sig}" | base64 -d > "${_v_sig}" 2>/dev/null
        if ! zlar_crypto_verify "${CONST_PUBKEY}" "${_v_hash}" "${_v_sig}" "${prop_algo}"; then
            rm -f "${_v_canon}" "${_v_hash}" "${_v_sig}"
            fail "Proposal signature is INVALID — cannot ratify"
        fi
        rm -f "${_v_canon}" "${_v_hash}" "${_v_sig}"
        ok "Proposal signature verified"
    fi

    # Check cooling-off period using SIGNED proposal timestamp (adversarial reviewer's requirement)
    local proposed_at deadline
    proposed_at=$(jq -r '.proposed_at' "${proposal_file}" 2>/dev/null)
    deadline=$(jq -r '.cooling_off_deadline' "${proposal_file}" 2>/dev/null)
    local now_iso
    now_iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    if [[ "${now_iso}" < "${deadline}" ]]; then
        local remaining
        local now_epoch deadline_epoch
        now_epoch=$(date +%s)
        # Parse deadline to epoch
        deadline_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "${deadline}" +%s 2>/dev/null || date -d "${deadline}" +%s 2>/dev/null)
        remaining=$(( (deadline_epoch - now_epoch) / 3600 ))
        fail "Cooling-off period has NOT elapsed. ${remaining} hours remaining (deadline: ${deadline}). DP-02 requires nonzero constitutional delay."
    fi

    ok "Cooling-off period elapsed (proposed: ${proposed_at}, deadline: ${deadline})"

    # Second signing act — ratification signature includes state transition
    local ratify_payload
    ratify_payload=$(jq -c --arg state "ratified" --arg ts "${now_iso}" \
        '.state = $state | .ratified_at = $ts' "${proposal_file}")

    local r_canon r_hash r_sig
    r_canon=$(mktemp /tmp/zlar-ratify-sign-canon.XXXXXX)
    r_hash=$(mktemp /tmp/zlar-ratify-sign-hash.XXXXXX)
    r_sig=$(mktemp /tmp/zlar-ratify-sign-sig.XXXXXX)

    echo "${ratify_payload}" | jq -S -c '.signature = {algorithm:"",value:"",key_id:""}' > "${r_canon}"
    zlar_crypto_hash "${r_canon}" "${r_hash}"

    if ! zlar_crypto_sign "${key}" "${r_hash}" "${r_sig}"; then
        rm -f "${r_canon}" "${r_hash}" "${r_sig}"
        fail "Failed to sign ratification"
    fi

    local r_sig_b64
    r_sig_b64=$(base64 < "${r_sig}" | tr -d '\n')
    local r_algo
    r_algo=$(zlar_crypto_algorithm)

    rm -f "${r_canon}" "${r_hash}" "${r_sig}"

    # Get ratifier fingerprint
    local ratifier_fp
    local r_pub_tmp
    r_pub_tmp=$(mktemp /tmp/zlar-ratify-pub.XXXXXX)
    if zlar_crypto_extract_pubkey "${key}" "${r_pub_tmp}" 2>/dev/null; then
        ratifier_fp=$(zlar_crypto_pubkey_fingerprint "${r_pub_tmp}" 2>/dev/null || echo "unknown")
    else
        ratifier_fp="unknown"
    fi
    rm -f "${r_pub_tmp}"

    # Write ratified proposal
    local ratified
    ratified=$(echo "${ratify_payload}" | jq -c \
        --arg algo "${r_algo}" \
        --arg sig "${r_sig_b64}" \
        --arg key_id "${ratifier_fp}" \
        '.signature.algorithm = $algo | .signature.value = $sig | .signature.key_id = $key_id')

    echo "${ratified}" | jq '.' > "${proposal_file}"

    ok "Amendment ratified: ${proposal}"
    local target_path proposed_value
    target_path=$(jq -r '.target_path' "${proposal_file}" 2>/dev/null)
    proposed_value=$(jq -r '.proposed_value' "${proposal_file}" 2>/dev/null)
    info "Target: ${target_path}"
    info "Proposed value: ${proposed_value}"
    echo ""

    # OB-03
    local ob03_delivered="false"
    if _notify_telegram "Amendment Ratified" "*Proposal:* \`${proposal}\`
*Path:* \`${target_path}\`
*Value:* ${proposed_value}
*Ratified at:* ${now_iso}" 2>/dev/null; then
        ob03_delivered="true"
        ok "OB-03: Telegram notification delivered"
    else
        warn "OB-03: Telegram notification not delivered"
    fi
    jq --arg event "ratified" --arg ts "${now_iso}" --argjson delivered "${ob03_delivered}" \
        '.ob03_notifications += [{event: $event, delivered: $delivered, ts: $ts}]' \
        "${proposal_file}" > "${proposal_file}.tmp"
    mv "${proposal_file}.tmp" "${proposal_file}"

    info "Ready to activate: zlar-constitution activate --proposal ${proposal} --key <key>"
}

# ─── Activate Amendment ─────────────────────────────────────────────────────

cmd_activate() {
    local proposal="" key=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --proposal) shift; proposal="$1"; shift ;;
            --key)      shift; key="$1"; shift ;;
            *) shift ;;
        esac
    done

    if [ -z "${proposal}" ]; then
        fail "Missing --proposal <proposal-id>"
    fi
    if [ -z "${key}" ]; then
        fail "Missing --key <constitutional-private-key> (explicit key required for ceremony acts)"
    fi
    if [ ! -f "${key}" ]; then
        fail "Constitutional key not found: ${key}"
    fi

    local proposal_file="${AMENDMENTS_DIR}/${proposal}.proposal.json"
    if [ ! -f "${proposal_file}" ]; then
        fail "Proposal not found: ${proposal}"
    fi

    echo -e "${BOLD}Activating Amendment${NC}"
    echo ""

    # Check state
    local state
    state=$(jq -r '.state' "${proposal_file}" 2>/dev/null)
    if [ "${state}" != "ratified" ]; then
        fail "Proposal is in state '${state}', must be 'ratified' to activate"
    fi

    if [ ! -f "${CONSTITUTION_FILE}" ]; then
        fail "No deployed constitution"
    fi

    # Apply proposed change to a copy and run DP-03
    local target_path proposed_value
    target_path=$(jq -r '.target_path' "${proposal_file}" 2>/dev/null)
    proposed_value=$(jq -c '.proposed_value' "${proposal_file}" 2>/dev/null)

    local candidate
    candidate=$(mktemp /tmp/zlar-activate-candidate.XXXXXX)
    jq --argjson val "${proposed_value}" ".${target_path} = \$val" "${CONSTITUTION_FILE}" > "${candidate}" 2>/dev/null

    info "Running DP-03 consistency check..."
    local dp03_output
    dp03_output=$(_dp03_check "${candidate}" 2>&1)
    local dp03_rc=$?

    if [ ${dp03_rc} -ne 0 ]; then
        echo -e "${RED}  DP-03 FAILED:${NC}"
        echo "${dp03_output}" | while read -r line; do
            echo -e "    ${RED}✗${NC} ${line}"
        done
        rm -f "${candidate}"
        fail "Amendment activation rejected — DP-03 consistency check failed. The proposed parameter set violates constitutional obligations."
    fi

    ok "DP-03: Parameter consistency verified"

    # Re-sign the constitution with the amendment applied
    info "Applying amendment and re-signing constitution..."

    # Get algorithm and public key
    local algo pubkey_b64
    algo=$(zlar_crypto_algorithm)
    pubkey_b64=$(zlar_crypto_pubkey_b64 "${key}")

    # Build new constitution with empty signature for canonical form
    local new_const
    new_const=$(jq --arg pubkey "${pubkey_b64}" --arg algo "${algo}" \
        '.signature.algorithm = $algo | .signature.public_key = $pubkey | .signature.value = ""' \
        "${candidate}")

    local c_canon c_hash c_sig
    c_canon=$(mktemp /tmp/zlar-activate-canon.XXXXXX)
    c_hash=$(mktemp /tmp/zlar-activate-hash.XXXXXX)
    c_sig=$(mktemp /tmp/zlar-activate-sig.XXXXXX)

    echo "${new_const}" > "${c_canon}"
    zlar_crypto_hash "${c_canon}" "${c_hash}"

    if ! zlar_crypto_sign "${key}" "${c_hash}" "${c_sig}"; then
        rm -f "${candidate}" "${c_canon}" "${c_hash}" "${c_sig}"
        fail "Failed to sign amended constitution"
    fi

    local c_sig_b64
    c_sig_b64=$(base64 < "${c_sig}" | tr -d '\n')

    # Final signed constitution
    local final_const
    final_const=$(echo "${new_const}" | jq --arg sig "${c_sig_b64}" '.signature.value = $sig')

    rm -f "${candidate}" "${c_canon}" "${c_hash}" "${c_sig}"

    # Archive current constitution
    local current_version
    current_version=$(jq -r '.constitution_version // "unknown"' "${CONSTITUTION_FILE}" 2>/dev/null)
    local archive_dir="${ZLAR_ROOT}/constitutions/archive"
    mkdir -p "${archive_dir}" 2>/dev/null || true
    local archive_name="constitution-v${current_version}-pre-${proposal}-$(date +%Y%m%d%H%M%S).json"
    cp "${CONSTITUTION_FILE}" "${archive_dir}/${archive_name}"
    info "Archived pre-amendment constitution: ${archive_name}"

    # Atomic deploy
    local deploy_tmp="${CONSTITUTION_FILE}.deploying"
    echo "${final_const}" | jq '.' > "${deploy_tmp}"
    mv "${deploy_tmp}" "${CONSTITUTION_FILE}"

    # Update presence tracker
    shasum -a 256 "${CONSTITUTION_FILE}" | awk '{print $1}' > "${LOG_DIR}/.constitution-last-hash" 2>/dev/null || true

    # Invalidate session cache (force gate to re-validate)
    rm -f "${PROJECT_DIR}/var/log/sessions/"*.constitution-valid 2>/dev/null || true

    # Update proposal state
    local now_iso
    now_iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    jq --arg state "activated" --arg ts "${now_iso}" --arg archive "${archive_name}" \
        '.state = $state | .activated_at = $ts | .archive = $archive' \
        "${proposal_file}" > "${proposal_file}.tmp"
    mv "${proposal_file}.tmp" "${proposal_file}"

    ok "Amendment activated: ${proposal}"
    info "Constitution updated. Gate will validate on next invocation."
    echo ""

    # OB-03
    local ob03_delivered="false"
    if _notify_telegram "Amendment Activated" "*Proposal:* \`${proposal}\`
*Path:* \`${target_path}\`
*New value:* ${proposed_value}
*Activated at:* ${now_iso}
*Archive:* ${archive_name}" 2>/dev/null; then
        ob03_delivered="true"
        ok "OB-03: Telegram notification delivered"
    else
        warn "OB-03: Telegram notification not delivered"
    fi
    jq --arg event "activated" --arg ts "${now_iso}" --argjson delivered "${ob03_delivered}" \
        '.ob03_notifications += [{event: $event, delivered: $delivered, ts: $ts}]' \
        "${proposal_file}" > "${proposal_file}.tmp"
    mv "${proposal_file}.tmp" "${proposal_file}"
}

# ─── Withdraw Amendment ─────────────────────────────────────────────────────

cmd_withdraw() {
    local proposal="" key=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --proposal) shift; proposal="$1"; shift ;;
            --key)      shift; key="$1"; shift ;;
            *) shift ;;
        esac
    done

    if [ -z "${proposal}" ]; then
        fail "Missing --proposal <proposal-id>"
    fi
    if [ -z "${key}" ]; then
        fail "Missing --key <constitutional-private-key>"
    fi
    if [ ! -f "${key}" ]; then
        fail "Constitutional key not found: ${key}"
    fi

    local proposal_file="${AMENDMENTS_DIR}/${proposal}.proposal.json"
    if [ ! -f "${proposal_file}" ]; then
        fail "Proposal not found: ${proposal}"
    fi

    local state
    state=$(jq -r '.state' "${proposal_file}" 2>/dev/null)
    if [ "${state}" != "proposed" ] && [ "${state}" != "ratified" ]; then
        fail "Proposal is in state '${state}' — can only withdraw from 'proposed' or 'ratified'"
    fi

    echo -e "${BOLD}Withdrawing Amendment${NC}"
    echo ""

    local now_iso
    now_iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)

    # Sign the withdrawal (state transition in signed payload)
    local withdraw_payload
    withdraw_payload=$(jq -c --arg state "withdrawn" --arg ts "${now_iso}" \
        '.state = $state | .withdrawn_at = $ts' "${proposal_file}")

    local w_canon w_hash w_sig
    w_canon=$(mktemp /tmp/zlar-withdraw-canon.XXXXXX)
    w_hash=$(mktemp /tmp/zlar-withdraw-hash.XXXXXX)
    w_sig=$(mktemp /tmp/zlar-withdraw-sig.XXXXXX)

    echo "${withdraw_payload}" | jq -S -c '.signature = {algorithm:"",value:"",key_id:""}' > "${w_canon}"
    zlar_crypto_hash "${w_canon}" "${w_hash}"

    if ! zlar_crypto_sign "${key}" "${w_hash}" "${w_sig}"; then
        rm -f "${w_canon}" "${w_hash}" "${w_sig}"
        fail "Failed to sign withdrawal"
    fi

    local w_sig_b64
    w_sig_b64=$(base64 < "${w_sig}" | tr -d '\n')
    local w_algo
    w_algo=$(zlar_crypto_algorithm)

    rm -f "${w_canon}" "${w_hash}" "${w_sig}"

    local w_fp
    local w_pub_tmp
    w_pub_tmp=$(mktemp /tmp/zlar-withdraw-pub.XXXXXX)
    if zlar_crypto_extract_pubkey "${key}" "${w_pub_tmp}" 2>/dev/null; then
        w_fp=$(zlar_crypto_pubkey_fingerprint "${w_pub_tmp}" 2>/dev/null || echo "unknown")
    else
        w_fp="unknown"
    fi
    rm -f "${w_pub_tmp}"

    local withdrawn
    withdrawn=$(echo "${withdraw_payload}" | jq -c \
        --arg algo "${w_algo}" \
        --arg sig "${w_sig_b64}" \
        --arg key_id "${w_fp}" \
        '.signature.algorithm = $algo | .signature.value = $sig | .signature.key_id = $key_id')

    echo "${withdrawn}" | jq '.' > "${proposal_file}"

    ok "Amendment withdrawn: ${proposal}"
    local target_path
    target_path=$(jq -r '.target_path' "${proposal_file}" 2>/dev/null)
    info "Path: ${target_path}"
    info "Previous state: ${state}"
    echo ""

    # OB-03
    local ob03_delivered="false"
    if _notify_telegram "Amendment Withdrawn" "*Proposal:* \`${proposal}\`
*Path:* \`${target_path}\`
*Previous state:* ${state}
*Withdrawn at:* ${now_iso}" 2>/dev/null; then
        ob03_delivered="true"
        ok "OB-03: Telegram notification delivered"
    else
        warn "OB-03: Telegram notification not delivered"
    fi
    jq --arg event "withdrawn" --arg ts "${now_iso}" --argjson delivered "${ob03_delivered}" \
        '.ob03_notifications += [{event: $event, delivered: $delivered, ts: $ts}]' \
        "${proposal_file}" > "${proposal_file}.tmp"
    mv "${proposal_file}.tmp" "${proposal_file}"
}

# ─── Rollback Constitution ──────────────────────────────────────────────────
# Emergency restore of the most recent archived constitution.
# The decision to return is evidence (Intuitionist requirement).

cmd_rollback() {
    local key="" target=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --last)   target="last"; shift ;;
            --key)    shift; key="$1"; shift ;;
            *) shift ;;
        esac
    done

    if [ -z "${key}" ]; then
        fail "Missing --key <constitutional-private-key> (explicit key required for rollback)"
    fi
    if [ ! -f "${key}" ]; then
        fail "Constitutional key not found: ${key}"
    fi
    if [ "${target}" != "last" ]; then
        fail "Must specify --last (rollback to most recent archived constitution)"
    fi

    echo -e "${BOLD}Constitutional Rollback${NC}"
    echo ""

    local archive_dir="${ZLAR_ROOT}/constitutions/archive"
    if [ ! -d "${archive_dir}" ]; then
        fail "No constitutional archive directory"
    fi

    # Find most recent archive
    local latest_archive
    latest_archive=$(ls -t "${archive_dir}"/constitution-*.json 2>/dev/null | head -1)
    if [ -z "${latest_archive}" ]; then
        fail "No archived constitutions found"
    fi

    info "Rolling back to: $(basename "${latest_archive}")"

    # Verify archive signature
    if [ -f "${CONST_PUBKEY}" ]; then
        local _a_sig
        _a_sig=$(jq -r '.signature.value // ""' "${latest_archive}" 2>/dev/null)
        if [ -n "${_a_sig}" ] && [ "${_a_sig}" != "" ]; then
            local _a_canon _a_hash _a_sig_bin
            _a_canon=$(mktemp /tmp/zlar-rollback-canon.XXXXXX)
            _a_hash=$(mktemp /tmp/zlar-rollback-hash.XXXXXX)
            _a_sig_bin=$(mktemp /tmp/zlar-rollback-sig.XXXXXX)
            jq '.signature.value = ""' "${latest_archive}" > "${_a_canon}"
            zlar_crypto_hash "${_a_canon}" "${_a_hash}"
            echo "${_a_sig}" | base64 -d > "${_a_sig_bin}" 2>/dev/null
            if ! zlar_crypto_verify "${CONST_PUBKEY}" "${_a_hash}" "${_a_sig_bin}" "$(jq -r '.signature.algorithm // "ed25519"' "${latest_archive}" 2>/dev/null)"; then
                rm -f "${_a_canon}" "${_a_hash}" "${_a_sig_bin}"
                fail "Archived constitution signature INVALID — cannot rollback to tampered archive"
            fi
            rm -f "${_a_canon}" "${_a_hash}" "${_a_sig_bin}"
            ok "Archive signature verified"
        else
            warn "Archive is unsigned — proceeding with caution"
        fi
    fi

    # Run DP-03 on the archive (it was valid when archived, but verify)
    local dp03_output
    dp03_output=$(_dp03_check "${latest_archive}" 2>&1)
    if [ $? -ne 0 ]; then
        echo "${dp03_output}"
        fail "Archived constitution fails DP-03 — cannot rollback"
    fi
    ok "DP-03: Archived constitution passes consistency check"

    # Archive current (pre-rollback) constitution
    if [ -f "${CONSTITUTION_FILE}" ]; then
        local current_version
        current_version=$(jq -r '.constitution_version // "unknown"' "${CONSTITUTION_FILE}" 2>/dev/null)
        local pre_rollback="constitution-v${current_version}-pre-rollback-$(date +%Y%m%d%H%M%S).json"
        cp "${CONSTITUTION_FILE}" "${archive_dir}/${pre_rollback}"
        info "Archived pre-rollback constitution: ${pre_rollback}"
    fi

    # Deploy archived version
    local deploy_tmp="${CONSTITUTION_FILE}.deploying"
    cp "${latest_archive}" "${deploy_tmp}"
    mv "${deploy_tmp}" "${CONSTITUTION_FILE}"

    # Update presence tracker
    shasum -a 256 "${CONSTITUTION_FILE}" | awk '{print $1}' > "${LOG_DIR}/.constitution-last-hash" 2>/dev/null || true

    # Invalidate session cache
    rm -f "${PROJECT_DIR}/var/log/sessions/"*.constitution-valid 2>/dev/null || true

    # Create rollback receipt (Intuitionist requirement: the decision to return is evidence)
    local now_iso
    now_iso=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    local rollback_receipt
    rollback_receipt=$(jq -n -c \
        --arg ts "${now_iso}" \
        --arg restored_from "$(basename "${latest_archive}")" \
        --arg restored_version "$(jq -r '.constitution_version // "?"' "${latest_archive}" 2>/dev/null)" \
        --arg reason "emergency constitutional rollback" \
        '{event: "constitutional_rollback", timestamp: $ts, restored_from: $restored_from, restored_version: $restored_version, reason: $reason}')

    # Write to audit trail
    echo "${rollback_receipt}" >> "${LOG_DIR}/audit.jsonl" 2>/dev/null || true

    ok "Constitution rolled back to: $(basename "${latest_archive}")"
    local restored_version
    restored_version=$(jq -r '.constitution_version // "?"' "${CONSTITUTION_FILE}" 2>/dev/null)
    info "Active constitution: v${restored_version}"
    echo ""

    # OB-03
    _notify_telegram "Constitutional Rollback" "*Restored from:* $(basename "${latest_archive}")
*Version:* v${restored_version}
*Rolled back at:* ${now_iso}" 2>/dev/null || true
}

# ─── Amendment Status ───────────────────────────────────────────────────────

cmd_amendment_status() {
    local proposal=""

    while [ $# -gt 0 ]; do
        case "$1" in
            --proposal) shift; proposal="$1"; shift ;;
            *) shift ;;
        esac
    done

    if [ -n "${proposal}" ]; then
        # Show single proposal detail
        local proposal_file="${AMENDMENTS_DIR}/${proposal}.proposal.json"
        if [ ! -f "${proposal_file}" ]; then
            fail "Proposal not found: ${proposal}"
        fi
        echo -e "${BOLD}Amendment Detail: ${proposal}${NC}"
        echo ""
        jq '.' "${proposal_file}"
        return
    fi

    echo -e "${BOLD}Constitutional Amendments${NC}"
    echo ""

    if [ ! -d "${AMENDMENTS_DIR}" ] || [ -z "$(ls "${AMENDMENTS_DIR}"/*.proposal.json 2>/dev/null)" ]; then
        info "No amendments on record."
        return
    fi

    # Show delta-from-original if constitution exists (Bayesian's requirement)
    local show_delta="false"
    if [ -f "${CONSTITUTION_FILE}" ]; then
        show_delta="true"
    fi

    local now_epoch
    now_epoch=$(date +%s)

    for f in "${AMENDMENTS_DIR}"/*.proposal.json; do
        local pid state target proposed_at deadline
        pid=$(jq -r '.proposal_id' "${f}" 2>/dev/null)
        state=$(jq -r '.state' "${f}" 2>/dev/null)
        target=$(jq -r '.target_path' "${f}" 2>/dev/null)
        proposed_at=$(jq -r '.proposed_at' "${f}" 2>/dev/null)
        deadline=$(jq -r '.cooling_off_deadline' "${f}" 2>/dev/null)

        local state_color="${NC}"
        case "${state}" in
            proposed)  state_color="${YELLOW}" ;;
            ratified)  state_color="${BLUE}" ;;
            activated) state_color="${GREEN}" ;;
            withdrawn) state_color="${DIM}" ;;
        esac

        # Calculate age
        local proposed_epoch age_days
        proposed_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "${proposed_at}" +%s 2>/dev/null || date -d "${proposed_at}" +%s 2>/dev/null || echo "${now_epoch}")
        age_days=$(( (now_epoch - proposed_epoch) / 86400 ))

        echo -e "  ${state_color}${state}${NC}  ${pid}"
        echo -e "         Path: ${target}"
        echo -e "         Proposed: ${proposed_at} (${age_days}d ago)"

        if [ "${state}" = "proposed" ]; then
            if [[ "$(date -u +%Y-%m-%dT%H:%M:%SZ)" < "${deadline}" ]]; then
                echo -e "         ${YELLOW}Cooling-off until: ${deadline}${NC}"
            else
                echo -e "         ${GREEN}Ready to ratify${NC}"
            fi
        fi

        # OB-03 delivery status
        local ob03_count ob03_failed
        ob03_count=$(jq '.ob03_notifications | length' "${f}" 2>/dev/null)
        ob03_failed=$(jq '[.ob03_notifications[] | select(.delivered == false)] | length' "${f}" 2>/dev/null)
        if [ "${ob03_failed:-0}" -gt 0 ]; then
            echo -e "         ${RED}OB-03: ${ob03_failed}/${ob03_count} notifications failed${NC}"
        fi

        echo ""
    done

    # Delta-from-original view (Bayesian's drift visibility)
    if [ "${show_delta}" = "true" ]; then
        local activated_count
        activated_count=$(ls "${AMENDMENTS_DIR}"/*.proposal.json 2>/dev/null | while read -r f; do
            jq -r 'select(.state == "activated") | .proposal_id' "${f}" 2>/dev/null
        done | wc -l | tr -d ' ')

        if [ "${activated_count}" -gt 0 ]; then
            echo -e "${BOLD}Cumulative Parameter Drift${NC}"
            echo ""
            for f in "${AMENDMENTS_DIR}"/*.proposal.json; do
                local s target cv pv
                s=$(jq -r '.state' "${f}" 2>/dev/null)
                [ "${s}" != "activated" ] && continue
                target=$(jq -r '.target_path' "${f}" 2>/dev/null)
                cv=$(jq -r '.current_value' "${f}" 2>/dev/null)
                pv=$(jq -r '.proposed_value' "${f}" 2>/dev/null)
                echo -e "  ${target}: ${cv} → ${pv}"
            done
            echo ""
        fi
    fi
}

# ─── Main Dispatch ───────────────────────────────────────────────────────────

cmd="${1:-help}"
shift 2>/dev/null || true

case "${cmd}" in
    keygen)             cmd_keygen "$@" ;;
    sign)               cmd_sign "$@" ;;
    verify)             cmd_verify "$@" ;;
    deploy)             cmd_deploy "$@" ;;
    inspect)            cmd_inspect "$@" ;;
    validate)           cmd_validate "$@" ;;
    propose-amendment)  cmd_propose_amendment "$@" ;;
    ratify)             cmd_ratify "$@" ;;
    activate)           cmd_activate "$@" ;;
    withdraw)           cmd_withdraw "$@" ;;
    rollback)           cmd_rollback "$@" ;;
    amendment-status)   cmd_amendment_status "$@" ;;

    help|--help|-h)
        echo "ZLAR Constitution CLI — Second Authority Law"
        echo ""
        echo "Commands:"
        echo "  keygen                        Generate constitutional keypair"
        echo "  sign   --input F --key K      Sign a constitution file"
        echo "  verify --input F              Verify constitution signature"
        echo "  deploy --input F              Deploy signed constitution"
        echo "  inspect [--input F]           Display constitution summary"
        echo "  validate --policy F           Check policy against constitution"
        echo ""
        echo "Amendment ceremony:"
        echo "  propose-amendment             Propose a change to amendable constraints"
        echo "  ratify                        Ratify a proposed amendment (after cooling-off)"
        echo "  activate                      Activate a ratified amendment (runs DP-03)"
        echo "  withdraw                      Withdraw a proposed or ratified amendment"
        echo "  rollback --last               Emergency restore of previous constitution"
        echo "  amendment-status              Show amendments and parameter drift"
        ;;

    *)
        fail "Unknown command: ${cmd}. Try: zlar-constitution help"
        ;;
esac
