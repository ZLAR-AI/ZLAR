#!/bin/bash
# zlar-registry — agent inventory and identity for ZLAR
#
# Answers the question: "What agents exist in this environment,
# and what have they been doing?"
#
# This closes the agent inventory gap. You cannot govern what you
# cannot see. The registry reads the audit trail — the single source
# of truth — and surfaces every agent that has ever requested a tool call.
#
# No separate registration needed. If the gate saw you, you're in the registry.
# The audit trail IS the registry. This tool is the lens.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# shellcheck source=../lib/audit-reader.sh
source "${PROJECT_DIR}/lib/audit-reader.sh"

# ── Usage ──

usage() {
    cat <<'EOF'
Usage: zlar-registry [command] [options]

Commands:
  list              List all known agents (default)
  show <agent_id>   Show detail for a specific agent
  sessions          Show all sessions grouped by agent
  activity          Show agent activity timeline (last 7 days)
  stats             Show aggregate statistics per agent

Options:
  --since <seconds>   Only consider events from the last N seconds
  --json              Output as JSON (default is human-readable)

The audit trail is the registry. If the gate saw it, it's here.
EOF
    exit 0
}

# ── Formatters ──

_header() {
    if [[ "${OUTPUT_JSON}" == "true" ]]; then return; fi
    printf '\n\033[1m%s\033[0m\n' "$1"
    printf '%*s\n' "${#1}" '' | tr ' ' '─'
}

_dim() { printf '\033[2m%s\033[0m' "$1"; }

# ── Core: extract agent inventory from audit trail ──

# All agents that have ever appeared, with first/last seen and event counts
registry_list() {
    local events
    if [[ -n "${SINCE_SECONDS:-}" ]]; then
        events=$(audit_events_since "${SINCE_SECONDS}")
    else
        events=$(_audit_cat)
    fi

    if [[ "${OUTPUT_JSON}" == "true" ]]; then
        echo "${events}" | jq -s '
            group_by(.agent_id) |
            map({
                agent_id: .[0].agent_id,
                host: .[0].host,
                user: .[0].user,
                first_seen: (map(.ts) | sort | first),
                last_seen: (map(.ts) | sort | last),
                total_events: length,
                sessions: ([.[].session_id] | unique | length),
                outcomes: (group_by(.outcome) | map({(.[0].outcome): length}) | add),
                domains: ([.[].domain] | unique | sort)
            }) | sort_by(.agent_id)
        '
        return
    fi

    _header "Agent Registry"

    echo "${events}" | jq -s '
        group_by(.agent_id) |
        map({
            agent_id: .[0].agent_id,
            host: .[0].host,
            user: .[0].user,
            first_seen: (map(.ts) | sort | first),
            last_seen: (map(.ts) | sort | last),
            total_events: length,
            sessions: ([.[].session_id] | unique | length),
            denials: ([.[] | select(.outcome == "deny")] | length),
            human_authorized: ([.[] | select(.outcome == "authorized")] | length)
        }) | sort_by(.agent_id) | .[]
    ' | while IFS= read -r agent; do
        local aid host user first last total sessions denials human_auth
        aid=$(echo "${agent}" | jq -r '.agent_id')
        host=$(echo "${agent}" | jq -r '.host')
        user=$(echo "${agent}" | jq -r '.user')
        first=$(echo "${agent}" | jq -r '.first_seen')
        last=$(echo "${agent}" | jq -r '.last_seen')
        total=$(echo "${agent}" | jq -r '.total_events')
        sessions=$(echo "${agent}" | jq -r '.sessions')
        denials=$(echo "${agent}" | jq -r '.denials')
        human_auth=$(echo "${agent}" | jq -r '.human_authorized')

        printf '\n  \033[1;36m%s\033[0m  %s@%s\n' "${aid}" "${user}" "${host}"
        printf '    first seen   %s\n' "${first}"
        printf '    last seen    %s\n' "${last}"
        printf '    events       %s across %s sessions\n' "${total}" "${sessions}"
        printf '    denials      %s\n' "${denials}"
        printf '    human auth   %s\n' "${human_auth}"
    done
    echo
}

# Detail for a single agent
registry_show() {
    local target_agent="${1:?Usage: zlar-registry show <agent_id>}"

    local events
    if [[ -n "${SINCE_SECONDS:-}" ]]; then
        events=$(audit_events_since "${SINCE_SECONDS}" | jq -c --arg a "${target_agent}" 'select(.agent_id == $a)')
    else
        events=$(_audit_cat | jq -c --arg a "${target_agent}" 'select(.agent_id == $a)')
    fi

    local count
    count=$(echo "${events}" | grep -c '^' || true)

    if [[ "${count}" -eq 0 ]]; then
        echo "No events found for agent: ${target_agent}" >&2
        exit 1
    fi

    if [[ "${OUTPUT_JSON}" == "true" ]]; then
        echo "${events}" | jq -s '{
            agent_id: .[0].agent_id,
            host: .[0].host,
            user: .[0].user,
            first_seen: (map(.ts) | sort | first),
            last_seen: (map(.ts) | sort | last),
            total_events: length,
            sessions: ([.[].session_id] | unique | sort),
            by_outcome: (group_by(.outcome) | map({(.[0].outcome): length}) | add),
            by_domain: (group_by(.domain) | map({(.[0].domain): length}) | add),
            by_rule: (group_by(.rule) | map({(.[0].rule): length}) | add | to_entries | sort_by(-.value) | from_entries),
            recent_denials: ([.[] | select(.outcome == "deny")] | sort_by(.ts) | reverse | .[0:10] | map({ts, domain, action: (.action[:80]), rule}))
        }'
        return
    fi

    _header "Agent: ${target_agent}"

    echo "${events}" | jq -s '
        {
            first: (map(.ts) | sort | first),
            last: (map(.ts) | sort | last),
            events: length,
            sessions: ([.[].session_id] | unique | length)
        }
    ' | jq -r '"    first seen   \(.first)\n    last seen    \(.last)\n    events       \(.events) across \(.sessions) sessions"'

    echo
    printf '  \033[1mOutcomes\033[0m\n'
    echo "${events}" | jq -s 'group_by(.outcome) | map({outcome: .[0].outcome, count: length}) | sort_by(-.count) | .[]' | \
        jq -r '"    \(.outcome)\t\(.count)"'

    echo
    printf '  \033[1mDomains\033[0m\n'
    echo "${events}" | jq -s 'group_by(.domain) | map({domain: .[0].domain, count: length}) | sort_by(-.count) | .[]' | \
        jq -r '"    \(.domain)\t\(.count)"'

    echo
    printf '  \033[1mTop Rules\033[0m\n'
    echo "${events}" | jq -s 'group_by(.rule) | map({rule: .[0].rule, count: length}) | sort_by(-.count) | .[0:10] | .[]' | \
        jq -r '"    \(.rule)\t\(.count)"'

    local denials
    denials=$(echo "${events}" | jq -c 'select(.outcome == "deny")' | tail -5)
    if [[ -n "${denials}" ]]; then
        echo
        printf '  \033[1mRecent Denials\033[0m\n'
        echo "${denials}" | jq -r '"    \(.ts)  \(.rule)  \(.action[:60])"'
    fi
    echo
}

# Sessions grouped by agent
registry_sessions() {
    local events
    if [[ -n "${SINCE_SECONDS:-}" ]]; then
        events=$(audit_events_since "${SINCE_SECONDS}")
    else
        events=$(_audit_cat)
    fi

    if [[ "${OUTPUT_JSON}" == "true" ]]; then
        echo "${events}" | jq -s '
            group_by(.agent_id) |
            map({
                agent_id: .[0].agent_id,
                sessions: (group_by(.session_id) | map({
                    session_id: .[0].session_id,
                    started: (map(.ts) | sort | first),
                    ended: (map(.ts) | sort | last),
                    events: length,
                    domains: ([.[].domain] | unique)
                }) | sort_by(.started) | reverse)
            }) | sort_by(.agent_id)
        '
        return
    fi

    _header "Sessions by Agent"

    echo "${events}" | jq -s '
        group_by(.agent_id) | .[] |
        .agent_id = .[0].agent_id |
        {
            agent_id: .agent_id,
            sessions: (group_by(.session_id) | map({
                sid: .[0].session_id,
                started: (map(.ts) | sort | first),
                ended: (map(.ts) | sort | last),
                events: length
            }) | sort_by(.started) | reverse | .[0:5])
        }
    ' | while IFS= read -r group; do
        local aid
        aid=$(echo "${group}" | jq -r '.agent_id')
        printf '\n  \033[1;36m%s\033[0m\n' "${aid}"
        echo "${group}" | jq -r '.sessions[] | "    \(.sid[:8])…  \(.started) → \(.ended)  (\(.events) events)"'
    done
    echo
}

# Activity timeline — last 7 days by default
registry_activity() {
    local window="${SINCE_SECONDS:-604800}"

    local events
    events=$(audit_events_since "${window}")

    if [[ "${OUTPUT_JSON}" == "true" ]]; then
        echo "${events}" | jq -s '
            group_by(.agent_id) |
            map({
                agent_id: .[0].agent_id,
                daily: (
                    group_by(.ts[:10]) |
                    map({
                        date: .[0].ts[:10],
                        events: length,
                        denials: ([.[] | select(.outcome == "deny")] | length),
                        human_auth: ([.[] | select(.outcome == "authorized")] | length)
                    }) | sort_by(.date)
                )
            }) | sort_by(.agent_id)
        '
        return
    fi

    _header "Agent Activity (last $(( window / 86400 )) days)"

    echo "${events}" | jq -s '
        group_by(.agent_id) | .[] |
        {
            agent_id: .[0].agent_id,
            daily: (
                group_by(.ts[:10]) |
                map({
                    date: .[0].ts[:10],
                    events: length,
                    denials: ([.[] | select(.outcome == "deny")] | length)
                }) | sort_by(.date)
            )
        }
    ' | while IFS= read -r agent_data; do
        local aid
        aid=$(echo "${agent_data}" | jq -r '.agent_id')
        printf '\n  \033[1;36m%s\033[0m\n' "${aid}"
        echo "${agent_data}" | jq -r '.daily[] | "    \(.date)  \(.events) events  \(.denials) denied"'
    done
    echo
}

# Aggregate stats per agent
registry_stats() {
    local events
    if [[ -n "${SINCE_SECONDS:-}" ]]; then
        events=$(audit_events_since "${SINCE_SECONDS}")
    else
        events=$(_audit_cat)
    fi

    if [[ "${OUTPUT_JSON}" == "true" ]]; then
        echo "${events}" | jq -s '
            {
                total_agents: ([.[].agent_id] | unique | length),
                total_events: length,
                total_sessions: ([.[].session_id] | unique | length),
                agents: (
                    group_by(.agent_id) | map({
                        agent_id: .[0].agent_id,
                        events: length,
                        sessions: ([.[].session_id] | unique | length),
                        denial_rate: (([.[] | select(.outcome == "deny")] | length) / (length) * 100 | . * 10 | round / 10),
                        human_auth_rate: (([.[] | select(.outcome == "authorized")] | length) / (length) * 100 | . * 10 | round / 10),
                        avg_risk: (([.[].risk_score] | add) / length | . * 10 | round / 10),
                        top_domain: (group_by(.domain) | sort_by(-length) | .[0][0].domain)
                    }) | sort_by(-.events)
                )
            }
        '
        return
    fi

    _header "Registry Statistics"

    local total_agents total_events total_sessions
    total_agents=$(echo "${events}" | jq -s '[.[].agent_id] | unique | length')
    total_events=$(echo "${events}" | grep -c '^' || true)
    total_sessions=$(echo "${events}" | jq -s '[.[].session_id] | unique | length')

    printf '    agents       %s\n' "${total_agents}"
    printf '    events       %s\n' "${total_events}"
    printf '    sessions     %s\n' "${total_sessions}"

    echo
    echo "${events}" | jq -s '
        group_by(.agent_id) | map({
            agent_id: .[0].agent_id,
            events: length,
            denial_pct: (([.[] | select(.outcome == "deny")] | length) * 100 / length | . * 10 | round / 10),
            human_pct: (([.[] | select(.outcome == "authorized")] | length) * 100 / length | . * 10 | round / 10),
            avg_risk: (([.[].risk_score] | add) / length | . * 10 | round / 10)
        }) | sort_by(-.events) | .[]
    ' | jq -r '"    \(.agent_id)\t\(.events) events\t\(.denial_pct)% denied\t\(.human_pct)% human\tavg risk \(.avg_risk)"'
    echo
}

# ── Main ──

OUTPUT_JSON="false"
SINCE_SECONDS=""
COMMAND="list"

while [[ $# -gt 0 ]]; do
    case "$1" in
        list|show|sessions|activity|stats)
            COMMAND="$1"
            shift
            ;;
        --json)
            OUTPUT_JSON="true"
            shift
            ;;
        --since)
            SINCE_SECONDS="$2"
            shift 2
            ;;
        -h|--help)
            usage
            ;;
        *)
            # If command is show, next arg is agent_id
            if [[ "${COMMAND}" == "show" ]]; then
                SHOW_AGENT="$1"
                shift
            else
                echo "Unknown argument: $1" >&2
                usage
            fi
            ;;
    esac
done

case "${COMMAND}" in
    list)     registry_list ;;
    show)     registry_show "${SHOW_AGENT:-}" ;;
    sessions) registry_sessions ;;
    activity) registry_activity ;;
    stats)    registry_stats ;;
esac
